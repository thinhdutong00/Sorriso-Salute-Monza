---
import "../styles/global.css";

const asset = (name: string) => `/assets/original/images/${name}`;
const generated = (name: string) => `/assets/generated/${name}`;
const brandLogo = "/assets/brand/sorriso-salute-logo.png";
const heroImage = "/assets/brand/sorriso-salute-hero-waiting-room.png";
const dentistCutout = "/assets/brand/dentist-cutout.png";

const navItems = [
  { label: "Vantaggi", href: "#vantaggi" },
  { label: "Metodo", href: "#metodo" },
  { label: "FAQ", href: "#faq" },
];

const advantages = [
  {
    icon: "scan",
    title: "Progettazione Digitale Preventiva",
    text: "Analizziamo l'anatomia ossea tramite uno studio tridimensionale prima dell'intervento. Questo ci permette di stabilire l'esatta posizione degli impianti in anticipo, eliminando ogni imprevisto in fase chirurgica.",
  },
  {
    icon: "guided",
    title: "Gestione del Comfort e del Dolore",
    text: "Utilizziamo tecniche d'intervento mininvasive associate alla sedazione cosciente. Il paziente affronta la seduta in uno stato di totale relax, senza avvertire stress, dolore o ansia.",
  },
  {
    icon: "fixed",
    title: "Protocollo di Monitoraggio e Stabilità",
    text: "Seguiamo il decorso post-operatorio attraverso controlli clinici programmati. Monitoriamo la corretta osteointegrazione biologica per garantire la massima stabilità e durata dell'impianto nel tempo.",
  },
];

const steps = [
  {
    number: "01",
    title: "Presenza e Stabilità a Monza dal 2003",
    text: "Siamo un ambulatorio polispecialistico radicato sul territorio da oltre vent'anni, non una catena low-cost o un franchising temporaneo. Questa storicità ti garantisce un punto di riferimento solido e sempre rintracciabile nel tempo, sia per l'esecuzione dell'intervento sia per i futuri controlli di manutenzione.",
    icon: "icon-consultation",
  },
  {
    number: "02",
    title: "Chirurgia Affidata Esclusivamente a Specialisti",
    text: "Il posizionamento degli impianti non viene mai delegato a medici neolaureati o dentisti generici. Ogni trattamento è eseguito da un'équipe dedicata alla chirurgia orale, guidata dalla Dott.ssa Moreschi e sotto la stretta direzione sanitaria della Dott.ssa Pareja Carrillo, garantendo i massimi standard di rigore clinico.",
    icon: "icon-diagnosis",
  },
  {
    number: "03",
    title: "Gestione Immediata delle Urgenze in Giornata",
    text: "Il percorso non si esaurisce quando ti alzi dalla poltrona. In caso di dubbi o fastidi nel post-operatorio, applichiamo un protocollo interno rigido: ti assicuriamo una corsia preferenziale con visita e assistenza in sede il giorno stesso della tua chiamata, senza lasciarti mai solo.",
    icon: "icon-plan",
  },
  {
    number: "04",
    title: "Certificazione Finanziaria e Convenzioni Nazionali",
    text: "La trasparenza economica è totale, con preventivi chiari e bloccati prima dell'inizio delle cure, escludendo qualsiasi costo a sorpresa in corso d'opera. Inoltre, l'affidabilità e gli standard qualitativi della struttura sono certificati dall'accreditamento con i più importanti fondi sanitari e assicurazioni italiani, sia in forma diretta che indiretta, oltre alla possibilità di accedere a piani di rateizzazione personalizzati attraverso istituti partner come Compass.",
    icon: "icon-followup",
  },
];

const testimonials = [
  {
    quote:
      "Trattamento di impianti dentali: intervento impeccabile e risultato finale perfetto. Studio moderno, personale gentile e medico professionale.",
    name: "Marialuisa Mariani",
    source: "Recensione Google",
    initials: "MM",
  },
  {
    quote:
      "Ci sono stato per fare un impianto, devo ringraziare il dottore e le assistenti: persone gentilissime e molto preparate.",
    name: "Giuseppe Consolandi",
    source: "Recensione Google",
    initials: "GC",
  },
  {
    quote:
      "Ho effettuato un intervento con impianti: tutto perfetto. Bravi e attenti, ne è valsa la pena.",
    name: "Alex Oggiano",
    source: "Recensione Google",
    initials: "AO",
  },
];

const faqs = [
  {
    q: "Quando è indicato un impianto dentale?",
    a: "Un impianto può essere valutato quando manca uno o più denti e ci sono condizioni cliniche favorevoli. La decisione dipende da osso disponibile, salute gengivale, abitudini e obiettivi protesici.",
  },
  {
    q: "Serve una TAC o una diagnosi 3D?",
    a: "Spesso sì, soprattutto per pianificare posizione degli impianti, volumi ossei e rapporti con strutture anatomiche importanti. Se necessaria, viene proposta dopo la prima valutazione.",
  },
  {
    q: "Quanto dura un percorso implantare?",
    a: "Dipende dal caso. Un impianto singolo può richiedere fasi diverse tra diagnosi, intervento, guarigione e corona. Le riabilitazioni estese o con poco osso possono richiedere più tempo.",
  },
  {
    q: "Posso avere denti fissi subito?",
    a: "In alcuni casi è possibile valutare un carico immediato, ma non è indicato per tutti. Serve verificare stabilità, osso disponibile e tipo di riabilitazione.",
  },
  {
    q: "Cosa succede se ho poco osso?",
    a: "La mancanza di osso non esclude automaticamente gli impianti. Si valutano alternative protesiche, rigenerazione ossea o percorsi preparatori in base alla situazione clinica.",
  },
  {
    q: "Quanto costa un impianto?",
    a: "Il costo dipende da diagnosi, numero di impianti, eventuali procedure preparatorie e tipo di protesi. Dopo la visita ricevi un preventivo leggibile con fasi e alternative.",
  },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Studio Dentistico Sorriso & Salute a Monza: implantologia dentale, diagnosi 3D e piano chirurgico-protesico chiaro."
    />
    <title>Studio Dentistico Sorriso & Salute - Implantologia dentale a Monza</title>
  </head>
  <body>
    <header class="site-header" data-header>
      <a class="brand" href="#home" aria-label="Studio Dentistico Sorriso & Salute">
        <img class="brand-logo" src={brandLogo} alt="Studio Dentistico Sorriso & Salute" />
      </a>

      <nav class="desktop-nav" aria-label="Navigazione principale">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <a class="header-cta" href="/richiesta/">
        <span>Prenota visita implantologica</span>
        <span aria-hidden="true">-&gt;</span>
      </a>

      <button class="menu-button" type="button" aria-label="Apri menu" aria-expanded="false" data-menu-button>
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="mobile-nav" aria-label="Menu mobile" data-mobile-nav>
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href="/richiesta/">Prenota visita implantologica</a>
      </nav>
    </header>

    <main id="home">
      <section class="hero" aria-label="Studio Dentistico Sorriso & Salute">
        <img class="hero-bg" src={heroImage} alt="Sala d'attesa dello Studio Dentistico Sorriso & Salute" />
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <p class="eyebrow">Studio odontoiatrico a Monza</p>
          <h1>
            Ripristina la stabilità del tuo sorriso con <span>l'Implantologia Guidata a Carico Immediato</span>
          </h1>
          <p class="hero-lead">
            Grazie alla pianificazione digitale 3D e alla sedazione cosciente, affronti l'intervento senza l'ansia del dolore. Un percorso trasparente, garantito da protocolli di controllo post-operatorio inclusi, per proteggere la salute della tua bocca nel tempo.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/richiesta/">
              Prenota visita implantologica <span aria-hidden="true">-&gt;</span>
            </a>
            <a class="button button-secondary" href="#vantaggi">Scopri il metodo</a>
          </div>
          <p class="hero-note">
            Visita conoscitiva e studio radiografico preliminare eseguiti direttamente dal Direttore Sanitario.
          </p>
          <div class="social-proof" aria-label="Recensioni pazienti">
            <div class="avatar-row" aria-hidden="true">
              {["client-30.jpg", "client-40.jpg", "client-50.jpg", "client-60.jpg", "client-70.jpg"].map((img) => (
                <img src={asset(img)} alt="" />
              ))}
            </div>
            <p><strong>4.9/5</strong> da pazienti</p>
          </div>
        </div>
      </section>

      <section class="section section-muted pain-section" id="situazioni">
        <div class="section-heading centered">
          <p class="eyebrow teal">Prima della visita</p>
          <h2>Ti ritrovi in una di queste situazioni?</h2>
          <p>
            Un elenco visivo dei problemi quotidiani: non solo clinici, ma anche emotivi e sociali.
          </p>
        </div>

        <div class="pain-grid" aria-label="Situazioni frequenti">
          <article class="pain-card">
            <span aria-hidden="true">01</span>
            <p>Metti la mano davanti alla bocca quando ridi o parli con gli altri.</p>
          </article>
          <article class="pain-card">
            <span aria-hidden="true">02</span>
            <p>Rinunci alla carne o ai cibi duri al ristorante per paura che salti un dente o per il dolore.</p>
          </article>
          <article class="pain-card">
            <span aria-hidden="true">03</span>
            <p>Hai paura di iniziare i lavori perché temi che il prezzo finale raddoppi a sorpresa.</p>
          </article>
          <article class="pain-card">
            <span aria-hidden="true">04</span>
            <p>Sei terrorizzato dalla poltrona del dentista per via di un trauma passato.</p>
          </article>
        </div>

        <div class="pain-cta">
          <a class="button button-dark" href="/richiesta/">Richiedi una valutazione</a>
        </div>
      </section>

      <section class="section section-muted" id="vantaggi">
        <div class="advantage-layout">
          <div class="advantage-media">
            <div class="image-stack">
              <img class="main-image" src={generated("dental-advantage.png")} alt="Studio dentistico moderno con riunito odontoiatrico" loading="lazy" />
              <div class="floating-note">
                <strong>Prima visita implantologica</strong>
                <span>Diagnosi, fattibilità e alternative</span>
              </div>
            </div>
            <a class="button button-dark advantage-cta" href="/richiesta/">Prenota una Visita Ora</a>
          </div>

          <div class="advantage-copy">
            <p class="eyebrow teal">Perché sceglierci</p>
            <h2>
              Il Metodo Clinico: Come Gestiamo il Tuo Percorso
            </h2>
            <p>
              Il nostro approccio è sviluppato per azzerare l'incertezza e ridurre al minimo il disagio del paziente, attraverso un protocollo strutturato in 3 fasi.
            </p>
            <div class="image-stack mobile-advantage-image" aria-hidden="true">
              <img class="main-image" src={generated("dental-advantage.png")} alt="" loading="lazy" />
              <div class="floating-note">
                <strong>Prima visita implantologica</strong>
                <span>Diagnosi, fattibilità e alternative</span>
              </div>
            </div>

            <div class="advantage-list">
              {advantages.map((item) => (
                <article>
                  <span class="advantage-icon" aria-hidden="true">
                    {item.icon === "scan" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M4 7V5a1 1 0 0 1 1-1h2" />
                        <path d="M17 4h2a1 1 0 0 1 1 1v2" />
                        <path d="M20 17v2a1 1 0 0 1-1 1h-2" />
                        <path d="M7 20H5a1 1 0 0 1-1-1v-2" />
                        <path d="M7 12h10" />
                        <path d="M9 9h6" />
                        <path d="M9 15h6" />
                      </svg>
                    )}
                    {item.icon === "guided" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 3v18" />
                        <path d="M3 12h18" />
                        <circle cx="12" cy="12" r="6" />
                        <circle cx="12" cy="12" r="1.8" />
                      </svg>
                    )}
                    {item.icon === "fixed" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 5c-1.7 1.2-2.4 3.1-1.9 5.4l1.4 6.7c.3 1.5 2.1 1.9 2.9.6l1-1.7c.8-1.3 2.6-1.3 3.4 0l1 1.7c.8 1.3 2.6.9 2.9-.6l1.4-6.7c.5-2.3-.2-4.2-1.9-5.4-1.1-.8-2.5-.9-3.8-.4l-.7.3c-.8.3-1.6.3-2.4 0l-.7-.3c-1.2-.5-2.6-.4-3.7.4Z" />
                        <path d="m8 11 2 2 4-5" />
                      </svg>
                    )}
                  </span>
                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </div>
                </article>
              ))}
            </div>
            <a class="button button-dark mobile-advantage-cta" href="/richiesta/">Prenota una Visita Ora</a>
          </div>
        </div>
      </section>

      <section class="section method-section" id="metodo">
        <div class="method-inner">
          <div class="method-content">
            <div class="section-heading dark method-heading">
              <p class="eyebrow mint">Siamo dalla tua parte</p>
              <h2>Trasparenza e Tutele Cliniche</h2>
              <p>
                La scelta di riabilitare il sorriso richiede massima chiarezza. Abbiamo eliminato ogni incertezza clinica ed economica formulando quattro garanzie scritte a salvaguardia del paziente.
              </p>
            </div>

            <div class="method-grid">
              {steps.map((step) => (
                <article class="method-card">
                  <span class="method-number">{step.number}</span>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </article>
              ))}
            </div>
          </div>

          <img class="method-dentist" src={dentistCutout} alt="" loading="eager" aria-hidden="true" />
        </div>
      </section>

      <section class="section section-white" id="recensioni">
        <div class="section-heading centered">
          <p class="eyebrow teal">Dicono di noi</p>
          <h2>Competenza ed affidabilità</h2>
          <p>Recensioni orientate a percorsi implantari e riabilitazioni.</p>
        </div>

        <div class="testimonial-grid">
          {testimonials.map((item) => (
            <article class="testimonial-card">
              <div class="stars" aria-label="Cinque stelle">★★★★★</div>
              <blockquote>"{item.quote}"</blockquote>
              <footer>
                <span class="testimonial-initial" aria-hidden="true">{item.initials}</span>
                <div>
                  <strong>{item.name}</strong>
                  <span>{item.source}</span>
                </div>
              </footer>
            </article>
          ))}
        </div>
      </section>

      <section class="section section-muted" id="faq">
        <div class="faq-wrap">
          <div class="section-heading">
            <p class="eyebrow teal">Domande frequenti</p>
            <h2>Dubbi sugli impianti?</h2>
            <p>Risposte su diagnosi, tempi, costi e fattibilità del percorso implantare.</p>
          </div>

          <div class="faq-list">
            {faqs.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary>
                  <span>{item.q}</span>
                  <span class="faq-icon" aria-hidden="true">+</span>
                </summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-section" id="contatto">
        <div class="contact-copy">
          <p class="eyebrow teal">Contatti</p>
          <h2>Non rimandare la salute della tua bocca. Blocca la tua consulenza.</h2>
          <p>
            Raccontaci quali denti mancano o quale problema vuoi risolvere tramite il modulo guidato multistep.
          </p>
        </div>

        <div class="contact-card">
          <div>
            <span>Modulo unico</span>
            <h3>Compila la richiesta in pochi passaggi.</h3>
            <p>
              Il percorso multistep raccoglie problema, obiettivo, preferenza di data e recapiti, poi prepara la richiesta da inviare allo studio.
            </p>
          </div>
          <a class="button button-dark" href="/richiesta/">
            Richiedi la Valutazione Clinica del Tuo Caso
          </a>
          <p class="contact-note">Un nostro consulente ti chiamerà entro 4 ore lavorative per confermare l'appuntamento.</p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <a class="brand footer-brand" href="#home" aria-label="Studio Dentistico Sorriso & Salute">
            <img class="brand-logo" src={brandLogo} alt="Studio Dentistico Sorriso & Salute" />
          </a>
          <p>Studio Dentistico Sorriso & Salute a Monza, con servizi odontoiatrici e percorsi dedicati all'implantologia.</p>
        </div>
        <div>
          <h3>Esplora</h3>
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/cookie-policy/">Cookie Policy</a>
        </div>
        <div>
          <h3>Contatti</h3>
          <a href="tel:+390392022489">+39 039 2022489</a>
          <a href="mailto:info@sorrisoesalute.it">info@sorrisoesalute.it</a>
          <span>Via Gaslini, 1 - 20090 Monza (MB)</span>
        </div>
      </div>
      <div class="footer-bottom">
        <span>Studio Dentistico Sorriso & Salute - P.IVA 03845830961</span>
        <span>Direttore Sanitario: Dott.ssa Maria Isabel Pareja Carrillo - Odontoiatra</span>
        <span>Autorizzazione sanitaria n. 2014/11</span>
        <span>Pubblicità conforme art. 1 della legge di bilancio 2019 (30/12/2018 n. 145)</span>
      </div>
    </footer>

    <script>
      const menuButton = document.querySelector("[data-menu-button]");
      const mobileNav = document.querySelector("[data-mobile-nav]");

      const closeMobileMenu = () => {
        menuButton?.setAttribute("aria-expanded", "false");
        mobileNav?.classList.remove("is-open");
      };

      menuButton?.addEventListener("click", () => {
        const expanded = menuButton.getAttribute("aria-expanded") === "true";
        menuButton.setAttribute("aria-expanded", String(!expanded));
        mobileNav?.classList.toggle("is-open", !expanded);
      });

      mobileNav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobileMenu);
      });

      window.addEventListener("hashchange", closeMobileMenu);

      document.querySelectorAll(".faq-item").forEach((item) => {
        item.addEventListener("toggle", () => {
          if (!(item instanceof HTMLDetailsElement) || !item.open) return;
          document.querySelectorAll(".faq-item").forEach((other) => {
            if (other !== item && other instanceof HTMLDetailsElement) other.open = false;
          });
        });
      });
    </script>
  </body>
</html>
