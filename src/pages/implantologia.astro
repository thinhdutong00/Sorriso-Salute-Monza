    <dialog class="convention-dialog convention-dialog--full" data-convention-dialog="tutte" aria-labelledby="convention-title-tutte">
      <div class="convention-panel convention-panel--full">
        <header class="convention-header convention-header--full">
          <div>
            <p class="eyebrow teal">Convenzioni studio</p>
            <h2 id="convention-title-tutte">Scopri le nostre convenzioni</h2>
            <p>Consulta gli enti, i fondi e le assicurazioni convenzionati con lo studio.</p>
          </div>
          <button class="convention-close" type="button" aria-label="Chiudi popup" data-convention-close>
            <span aria-hidden="true">×</span>
          </button>
        </header>

        <div class="convention-full-scroll">
          {conventionGroups.map((group) => (
            <section class="convention-full-section" aria-labelledby={`convention-full-title-${group.id}`}>
              <div class="convention-full-heading">
                <p class="eyebrow teal">Convenzioni studio</p>
                <h3 id={`convention-full-title-${group.id}`}>{group.title}</h3>
                <p>{group.description}</p>
              </div>

              <div class="convention-logo-grid">
                {group.logos.map((logo) => (
                  <div class="convention-logo-card">
                    <img src={logo.src} alt={logo.label} loading="lazy" />
                  </div>
                ))}
              </div>

              <a class="button button-dark convention-booking-cta" href="/richiesta/" data-booking-link>
                Prenota Ora la Tua Visita
              </a>
            </section>
          ))}
        </div>
      </div>
    </dialog>

    <script>
      const header = document.querySelector("[data-header]");
      const menuButton = document.querySelector("[data-menu-button]");
      const mobileNav = document.querySelector("[data-mobile-nav]");
      const hero = document.querySelector(".hero");
      const kebabPanel = document.querySelector("[data-kebab-menu]");
      const kebabBackdrop = document.querySelector("[data-kebab-backdrop]");
      const implantologyToggle = kebabPanel?.querySelector("[data-kebab-implantology-toggle]");
      const implantologyPanel = kebabPanel?.querySelector("[data-kebab-implantology-panel]");
      const stickyCta = document.querySelector("[data-activity-sticky-cta]");
      const footer = document.querySelector(".site-footer");
      const testimonialCarousel = document.querySelector("[data-testimonial-carousel]");
      const whatsappFloat = document.querySelector("[data-whatsapp-float]");
      const whatsappTrigger = document.querySelector("#faq");
      const revealSections = Array.from(document.querySelectorAll("[data-scroll-reveal]"));
      const revealCards = Array.from(document.querySelectorAll("[data-card-reveal]"));
      const revealElements = [...revealSections, ...revealCards];
      let lastScrollY = window.scrollY;

      const closeMobileMenu = () => {
        menuButton?.setAttribute("aria-expanded", "false");
        mobileNav?.classList.remove("is-open");
      };

      const setImplantologySubmenuState = (isOpen) => {
        if (!(implantologyToggle instanceof HTMLButtonElement) || !(implantologyPanel instanceof HTMLElement)) return;

        implantologyToggle.setAttribute("aria-expanded", String(isOpen));
        implantologyPanel.hidden = !isOpen;
      };

      const setKebabMenuState = (isOpen) => {
        if (!(kebabPanel instanceof HTMLElement) || !(kebabBackdrop instanceof HTMLElement)) return;

        setImplantologySubmenuState(false);
        kebabPanel.hidden = !isOpen;
        kebabBackdrop.hidden = !isOpen;
        document.body.classList.toggle("kebab-menu-open", isOpen);
        document.querySelectorAll("[data-kebab-menu-toggle]").forEach((button) => {
          button.setAttribute("aria-expanded", String(isOpen));
        });

        if (isOpen) {
          closeMobileMenu();
          header?.classList.remove("is-hidden");
          kebabPanel.focus({ preventScroll: true });
        }
      };

      const updateHeaderTone = () => {
        if (!(header instanceof HTMLElement)) return;
        const heroBottom = hero instanceof HTMLElement ? hero.getBoundingClientRect().bottom : 0;
        const headerHeight = header.getBoundingClientRect().height || 96;
        header.classList.toggle("is-over-hero", heroBottom > headerHeight * 0.72);
      };

      menuButton?.addEventListener("click", () => {
        const expanded = menuButton.getAttribute("aria-expanded") === "true";
        menuButton.setAttribute("aria-expanded", String(!expanded));
        mobileNav?.classList.toggle("is-open", !expanded);
        setKebabMenuState(false);
        header?.classList.remove("is-hidden");
      });

      const updateStickyHeader = () => {
        if (!header) return;
        const currentScrollY = window.scrollY;
        const isMenuOpen = mobileNav?.classList.contains("is-open");
        const isKebabOpen = kebabPanel instanceof HTMLElement && !kebabPanel.hidden;
        const scrollDelta = currentScrollY - lastScrollY;

        updateHeaderTone();

        if (currentScrollY < 24 || isMenuOpen || isKebabOpen) {
          header.classList.remove("is-hidden");
          lastScrollY = currentScrollY;
          return;
        }

        if (Math.abs(scrollDelta) < 6) return;

        if (scrollDelta > 0) {
          closeMobileMenu();
          header.classList.add("is-hidden");
        } else {
          header.classList.remove("is-hidden");
        }

        lastScrollY = currentScrollY;
      };

      window.addEventListener("scroll", updateStickyHeader, { passive: true });
      window.addEventListener("resize", updateStickyHeader);

      mobileNav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobileMenu);
      });

      kebabPanel?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setKebabMenuState(false));
      });

      implantologyToggle?.addEventListener("click", () => {
        if (!(implantologyToggle instanceof HTMLButtonElement)) return;
        const isOpen = implantologyToggle.getAttribute("aria-expanded") !== "true";
        setImplantologySubmenuState(isOpen);
      });

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;

        const toggle = event.target.closest("[data-kebab-menu-toggle]");
        if (toggle) {
          event.preventDefault();
          setKebabMenuState(kebabPanel instanceof HTMLElement ? kebabPanel.hidden : true);
          return;
        }

        if (event.target.closest("[data-kebab-menu-close]") || event.target === kebabBackdrop) {
          event.preventDefault();
          setKebabMenuState(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") return;
        closeMobileMenu();
        setKebabMenuState(false);
      });

      window.addEventListener("hashchange", () => {
        closeMobileMenu();
        setKebabMenuState(false);
      });

      document.querySelectorAll(".faq-item").forEach((item) => {
        item.addEventListener("toggle", () => {
          if (!(item instanceof HTMLDetailsElement) || !item.open) return;
          document.querySelectorAll(".faq-item").forEach((other) => {
            if (other !== item && other instanceof HTMLDetailsElement) other.open = false;
          });
        });
      });

      const closeConventionDialog = (dialog) => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        dialog.close();
        document.body.classList.remove("modal-open");
      };

      document.querySelectorAll("[data-convention-open]").forEach((button) => {
        button.addEventListener("click", () => {
          const target = button.getAttribute("data-convention-open");
          const dialog = document.querySelector(`[data-convention-dialog="${target}"]`);
          if (!(dialog instanceof HTMLDialogElement)) return;
          dialog.showModal();
          document.body.classList.add("modal-open");
        });
      });

      document.querySelectorAll(".convention-dialog").forEach((dialog) => {
        if (!(dialog instanceof HTMLDialogElement)) return;

        dialog.addEventListener("click", (event) => {
          if (event.target === dialog) closeConventionDialog(dialog);
        });

        dialog.addEventListener("close", () => {
          document.body.classList.remove("modal-open");
        });

        dialog.querySelectorAll("[data-convention-close]").forEach((button) => {
          button.addEventListener("click", () => closeConventionDialog(dialog));
        });
      });

      const updateBookingLinks = () => {
        document.querySelectorAll("[data-booking-link]").forEach((link) => {
          if (link instanceof HTMLAnchorElement) link.setAttribute("href", "/richiesta/");
        });
      };

      updateBookingLinks();

      const updateStickyCtaVisibility = () => {
        if (!(stickyCta instanceof HTMLElement)) return;
        const threshold = hero instanceof HTMLElement
          ? hero.getBoundingClientRect().bottom + window.scrollY - 24
          : Math.round(window.innerHeight * 0.72);
        const isPastHero = window.scrollY > threshold;
        const stickyCtaHeight = stickyCta.offsetHeight;
        const isAtFooterEnd = footer instanceof HTMLElement
          ? footer.getBoundingClientRect().bottom <= window.innerHeight + stickyCtaHeight + 8
          : false;

        stickyCta.classList.toggle("is-visible", isPastHero && !isAtFooterEnd);
      };

      const updateWhatsappVisibility = () => {
        if (!(whatsappFloat instanceof HTMLElement)) return;
        if (!(whatsappTrigger instanceof HTMLElement)) {
          whatsappFloat.classList.remove("is-visible");
          return;
        }

        const hasReachedFaq = whatsappTrigger.getBoundingClientRect().top <= window.innerHeight * 0.85;
        whatsappFloat.classList.toggle("is-visible", hasReachedFaq);
      };

      const setupTestimonials = () => {
        if (!(testimonialCarousel instanceof HTMLElement)) return;

        const track = testimonialCarousel.querySelector("[data-testimonial-track]");
        const cards = Array.from(testimonialCarousel.querySelectorAll("[data-testimonial-card]"));
        const prevButton = testimonialCarousel.querySelector("[data-testimonial-prev]");
        const nextButton = testimonialCarousel.querySelector("[data-testimonial-next]");
        const moreButton = testimonialCarousel.querySelector("[data-testimonial-more]");

        if (!(track instanceof HTMLElement) || !cards.length) return;

        const mobileQuery = window.matchMedia("(max-width: 680px)");
        const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
        const visibleDesktopCards = 3;
        const initialMobileCards = 4;
        const mobileStep = 3;
        const autoplayDelay = 4600;
        let currentIndex = 0;
        let mobileVisibleCount = initialMobileCards;
        let autoplayId;

        const maxIndex = () => Math.max(cards.length - visibleDesktopCards, 0);

        const setDesktopIndex = (index) => {
          currentIndex = (index + maxIndex() + 1) % (maxIndex() + 1);
          const firstCard = cards[0];
          const secondCard = cards[1];
          const cardStep = secondCard
            ? secondCard.getBoundingClientRect().left - firstCard.getBoundingClientRect().left
            : firstCard.getBoundingClientRect().width;
          track.style.transform = `translateX(-${currentIndex * cardStep}px)`;
        };

        const stopAutoplay = () => {
          if (!autoplayId) return;
          window.clearInterval(autoplayId);
          autoplayId = undefined;
        };

        const startAutoplay = () => {
          stopAutoplay();
          if (mobileQuery.matches || reducedMotionQuery.matches || cards.length <= visibleDesktopCards) return;
          autoplayId = window.setInterval(() => setDesktopIndex(currentIndex + 1), autoplayDelay);
        };

        const updateMobileCards = () => {
          cards.forEach((card, index) => {
            if (!(card instanceof HTMLElement)) return;
            card.hidden = index >= mobileVisibleCount;
          });

          if (moreButton instanceof HTMLButtonElement) {
            moreButton.hidden = mobileVisibleCount >= cards.length;
          }
        };

        const setMode = () => {
          if (mobileQuery.matches) {
            stopAutoplay();
            track.style.transform = "";
            mobileVisibleCount = Math.max(mobileVisibleCount, initialMobileCards);
            updateMobileCards();
            return;
          }

          cards.forEach((card) => {
            if (card instanceof HTMLElement) card.hidden = false;
          });

          if (moreButton instanceof HTMLButtonElement) moreButton.hidden = true;
          setDesktopIndex(Math.min(currentIndex, maxIndex()));
          startAutoplay();
        };

        prevButton?.addEventListener("click", () => {
          setDesktopIndex(currentIndex - 1);
          startAutoplay();
        });

        nextButton?.addEventListener("click", () => {
          setDesktopIndex(currentIndex + 1);
          startAutoplay();
        });

        moreButton?.addEventListener("click", () => {
          mobileVisibleCount = Math.min(mobileVisibleCount + mobileStep, cards.length);
          updateMobileCards();
        });

        mobileQuery.addEventListener("change", setMode);
        reducedMotionQuery.addEventListener("change", setMode);
        window.addEventListener("resize", () => {
          if (!mobileQuery.matches) setDesktopIndex(Math.min(currentIndex, maxIndex()));
        });

        setMode();
      };

      const showRevealElements = () => {
        revealElements.forEach((element) => {
          if (element instanceof HTMLElement) element.classList.add("is-visible");
        });
      };

      const setupRevealEffects = () => {
        if (!revealElements.length) return;

        const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
        if (reducedMotionQuery.matches || !("IntersectionObserver" in window)) {
          showRevealElements();
          return;
        }

        const revealElement = (element) => {
          element.classList.add("is-visible");
        };

        const setupRevealGroup = (elements, options, initialViewportFactor) => {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                revealElement(entry.target);
                observer.unobserve(entry.target);
              });
            },
            options
          );

          elements.forEach((element) => {
            if (!(element instanceof HTMLElement)) return;
            if (element.getBoundingClientRect().top < window.innerHeight * initialViewportFactor) {
              revealElement(element);
              return;
            }
            revealObserver.observe(element);
          });
        };

        setupRevealGroup(
          revealSections,
          {
            rootMargin: "0px 0px -4% 0px",
            threshold: 0.01,
          },
          0.92
        );

        setupRevealGroup(
          revealCards,
          {
            rootMargin: "0px 0px 16% 0px",
            threshold: 0.01,
          },
          1.08
        );
      };

      updateStickyHeader();
      updateStickyCtaVisibility();
      updateWhatsappVisibility();
      setupTestimonials();
      setupRevealEffects();
      window.addEventListener("scroll", updateStickyCtaVisibility, { passive: true });
      window.addEventListener("scroll", updateWhatsappVisibility, { passive: true });
      window.addEventListener("hashchange", updateWhatsappVisibility);
      window.addEventListener("resize", updateStickyCtaVisibility);
      window.addEventListener("resize", updateWhatsappVisibility);
    </script>
  </body>
