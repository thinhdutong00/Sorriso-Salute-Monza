  { label: "Assilt", src: "/assets/brand/convenzioni/indirette/05-assilt.jpg" },
  { label: "Cadgi", src: "/assets/brand/convenzioni/indirette/06-cadgi.jpg" },
  { label: "Fimiv", src: "/assets/brand/convenzioni/indirette/07-fimiv.jpg" },
  { label: "Odontonetwork", src: "/assets/brand/convenzioni/indirette/08-odontonetwork.jpg" },
  { label: "Fondo Salute", src: "/assets/brand/convenzioni/indirette/09-fondo-salute.jpg" },
];

const conventionGroups = [
  {
    id: "dirette",
    title: "Convenzioni dirette",
    description: "Fondi, assicurazioni e network con gestione diretta della pratica in studio.",
    source: "https://www.sorrisoesalute.it/convenzioni-dirette-studio-dentistico-monza/",
    logos: directConventions,
  },
  {
    id: "indirette",
    title: "Convenzioni indirette",
    description: "Enti e fondi per cui il paziente può informarsi sulle modalità di rimborso indiretto.",
    source: "https://www.sorrisoesalute.it/convenzioni-indirette/",
    logos: indirectConventions,
  },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Percorso implantologico a Monza: parti dalla tua situazione e scopri diagnosi, soluzioni su impianti e controlli con Sorriso & Salute."
    />
    <link rel="canonical" href="https://sorrisoesalutemonza.it/implantologia/" />
    <FaviconLinks />
    <GoogleAdsTracking />
    <title>Percorso implantologico a Monza | Sorriso &amp; Salute</title>
  </head>
  <body class="has-sticky-cta">
    <PageLoader />
    <ImplantologiaAttribution serviceInterest="Implantologia" isLanding />

    <header class="site-header is-over-hero" data-header>
      <a class="brand" href="/" aria-label="Studio Dentistico Sorriso & Salute">
        <span class="brand-logo implantologia-hub__logo-mark" aria-hidden="true"></span>
      </a>

      <nav class="desktop-nav" aria-label="Navigazione principale">
        {
          navItems.map((item) => (
            <a href={item.href}>
              <span>{item.label}</span>
              {
                item.icon === "phone" && (
                  <svg class="nav-link-icon" aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                    <path
                      d="M6.62 10.79c1.44 2.83 3.76 5.15 6.59 6.59l2.2-2.2c.31-.31.76-.42 1.17-.28 1.29.43 2.64.66 4.02.66.66 0 1.2.54 1.2 1.2v3.48c0 .66-.54 1.2-1.2 1.2C10.43 21.94 2.06 13.57 2.06 3.4c0-.66.54-1.2 1.2-1.2h3.49c.66 0 1.2.54 1.2 1.2 0 1.38.22 2.73.66 4.02.13.41.03.86-.29 1.17l-2.2 2.2Z"
                      fill="currentColor"
                    />
                  </svg>
                )
              }
            </a>
          ))
        }
      </nav>

      <button
        class="kebab-button"
        type="button"
        aria-label="Apri menu esteso"
        aria-controls="implantologia-kebab-menu"
        aria-expanded="false"
        data-kebab-menu-toggle
      >
        <span class="kebab-button__icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span>Menu</span>
      </button>

      <button
        class="menu-button"
        type="button"
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="implantologia-mobile-nav"
        data-menu-button
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav id="implantologia-mobile-nav" class="mobile-nav" aria-label="Menu mobile" data-mobile-nav>
        <details class="mobile-nav__treatments">
          <summary>Trattamenti</summary>
          <div class="mobile-nav__implantology-group" role="group" aria-labelledby="mobile-menu-implantology-label">
            <span class="mobile-nav__implantology-label" id="mobile-menu-implantology-label">Implantologia</span>
            <div class="mobile-nav__implantology-links">
              {implantologiaMenuLinks.map((link) => (
                <a href={link.href} aria-current={currentPath === link.href ? "page" : undefined} data-implantology-menu-link>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
          <a href={protesiDentaleMenuLink.href} aria-current={currentPath === protesiDentaleMenuLink.href ? "page" : undefined}>{protesiDentaleMenuLink.label}</a>
        </details>
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href="/richiesta/">Richiedi appuntamento</a>
      </nav>
    </header>

    <div class="kebab-backdrop" data-kebab-backdrop hidden></div>
    <aside id="implantologia-kebab-menu" class="kebab-menu" data-kebab-menu tabindex="-1" aria-label="Menu principale" hidden>
      <div class="kebab-menu__header">
        <button type="button" class="kebab-menu__close" data-kebab-menu-close aria-label="Chiudi menu">
          <span aria-hidden="true">×</span>
          Chiudi
        </button>
      </div>
      <nav class="kebab-menu__content" aria-label="Navigazione estesa">
        <section class="kebab-menu__section">
          <h2>Studio</h2>
          <a href="/chi-siamo/">Chi siamo</a>
          <a href="/struttura-studio-dentistico-monza/">La Struttura</a>
          <a href="/contatti/">Contatti</a>
          <a href="/convenzioni-dirette-studio-dentistico-monza/">Convenzioni</a>
        </section>
        <section class="kebab-menu__section kebab-menu__section--treatments">
          <h2>Trattamenti</h2>
          <a href={kebabAllTreatmentsLink.href}>{kebabAllTreatmentsLink.label}</a>
          <div class="kebab-menu__treatment-categories">
            {kebabTreatmentCategories.map((category) => (
              <div class="kebab-menu__treatment-category">
                <h3 class="kebab-menu__treatment-category-title">{category.label}</h3>
                <div class="kebab-menu__treatment-category-items">
                  {category.items.map((item) => (
                    item.kind === "implantology" ? (
                      <div class="kebab-menu__implantology-group" role="group" aria-labelledby="implantologia-hub-menu-label">
                        <button
                          class="kebab-menu__implantology-parent"
                          id="implantologia-hub-menu-label"
                          type="button"
                          aria-expanded="false"
                          aria-controls="implantologia-hub-menu-links"
                          data-kebab-implantology-toggle
                        >
                          <span class="kebab-menu__implantology-label">{item.label}</span>
                          <span class="kebab-menu__implantology-chevron" aria-hidden="true"></span>
                        </button>
                        <div
                          id="implantologia-hub-menu-links"
                          class="kebab-menu__implantology-links"
                          data-kebab-implantology-panel
                          hidden
                        >
                          {item.children.map((link) => (
                            <a href={link.href} aria-current={currentPath === link.href ? "page" : undefined} data-implantology-menu-link>
                              {link.label}
                            </a>
                          ))}
                        </div>
                      </div>
                    ) : (
                      <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                        {item.label}
                      </a>
                    )
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
        <section class="kebab-menu__section">
          <h2>Prenota e informazioni</h2>
          <a href="/urgenze/">Urgenze</a>
          <a href="tel:+390392022489">Chiama in studio: 039 2022489</a>
          <a href="/richiesta/">Richiedi appuntamento</a>
          <a href="/convenzioni-dirette/">Convenzioni dirette</a>
          <a href="/convenzioni-indirette/">Convenzioni indirette</a>
        </section>
      </nav>
    </aside>

    <main id="home">
      <section class="hero" aria-label="Percorso implantologico a Monza">
        <div class="hero-content">
          <h1>
            Percorso implantologico
          </h1>
          <p class="hero-breadcrumb hero-service-description">
            Sostituisci i denti mancanti con soluzioni stabili, progettate per tornare a sorridere e masticare con sicurezza.
          </p>
          <p class="hero-lead hero-lead-desktop">
            <strong>Dal 2003 a Monza, attraverso solo la chirurgia implantare, abbiamo aiutato oltre 10.000 persone a ritrovare la sicurezza di sorridere e il piacere di masticare senza dolore.</strong> Che ti manchi un solo dente o un'intera arcata, progettiamo la soluzione implantare su misura per restituirti il comfort che stai cercando.
          </p>
          <p class="hero-lead hero-lead-mobile">
            <strong>Dal 2003 a Monza, attraverso solo la chirurgia implantare, abbiamo aiutato oltre 10.000 persone a ritrovare la sicurezza di sorridere e il piacere di masticare senza dolore.</strong>
          </p>
        </div>
      </section>

      <section class="section section-white situations-section scroll-reveal" aria-labelledby="situazioni-oggi-title" data-scroll-reveal>
        <div class="section-heading centered">
          <p class="eyebrow teal">AFFIDATI AI NOSTRI SPECIALISTI</p>
          <h2 id="situazioni-oggi-title">In quale di queste situazioni ti trovi oggi?</h2>
          <p>
            <strong>Più di 10.000 impianti posizionati e protesi stabilizzate con successo in 23 anni di attività.</strong>
          </p>
        </div>

        <div class="situations-grid" aria-label="Situazioni implantari frequenti">
          {patientSituations.map((situation) => (
            <article class="situation-card card-reveal" data-card-reveal>
              <picture>
                <source
                  srcset={`${situation.optimizedImage}-480.avif 480w, ${situation.optimizedImage}-720.avif 720w, ${situation.optimizedImage}-1080.avif 1080w`}
                  sizes="(max-width: 680px) calc(100vw - 38px), (max-width: 1120px) calc((min(100vw - 48px, 760px) - 18px) / 2), calc((min(100vw - 48px, 1420px) - 72px) / 4)"
                  type="image/avif"
                />
                <img src={situation.image} alt="" width="640" height="420" loading="lazy" decoding="async" />
              </picture>
              <div class="situation-card__content">
                <span class="situation-card__label">{situation.label}</span>
                <h3>{situation.title}</h3>
                <p>{situation.text}</p>
                <div class="situation-card__actions">
                  <a class="situation-card__cta" href={situation.href}>{situation.cta}</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section section-muted scroll-reveal" id="vantaggi" data-scroll-reveal>
        <div class="advantage-layout">
          <div class="advantage-media">
            <div class="image-stack">
              <picture>
                <source srcset={advantageAvifSrcSet} sizes="(max-width: 760px) 84vw, 520px" type="image/avif" />
                <source srcset={advantageWebpSrcSet} sizes="(max-width: 760px) 84vw, 520px" type="image/webp" />
                <img
                  class="main-image"
                  src={generated("dental-advantage.png")}
                  alt="Studio dentistico moderno con riunito odontoiatrico"
                  width="1254"
                  height="1254"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <div class="floating-note">
                <strong>Prima visita implantologica</strong>
                <span>Diagnosi, fattibilità e alternative</span>
              </div>
            </div>
            <a class="button button-dark advantage-cta" href="/richiesta/">Prenota una Visita Ora</a>
          </div>

          <div class="advantage-copy">
            <p class="eyebrow teal">Il Metodo Clinico</p>
            <h2>
              Come Gestiamo il Tuo Percorso
            </h2>
            <p>
              Il percorso implantare viene costruito in 4 passaggi, dalla diagnosi iniziale alla protesi finale e ai controlli nel tempo.
            </p>
            <div class="image-stack mobile-advantage-image" aria-hidden="true">
              <picture>
                <source srcset={advantageAvifSrcSet} sizes="84vw" type="image/avif" />
                <source srcset={advantageWebpSrcSet} sizes="84vw" type="image/webp" />
                <img class="main-image" src={generated("dental-advantage.png")} alt="" width="1254" height="1254" loading="lazy" decoding="async" />
              </picture>
              <div class="floating-note">
                <strong>Prima visita implantologica</strong>
                <span>Diagnosi, fattibilità e alternative</span>
              </div>
            </div>

            <div class="advantage-list">
              {advantages.map((item) => (
                <article class="card-reveal" data-card-reveal>
                  <span class="advantage-icon" aria-hidden="true">
                    {item.icon === "scan" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M4 7V5a1 1 0 0 1 1-1h2" />
                        <path d="M17 4h2a1 1 0 0 1 1 1v2" />
                        <path d="M20 17v2a1 1 0 0 1-1 1h-2" />
                        <path d="M7 20H5a1 1 0 0 1-1-1v-2" />
                        <path d="M7 12h10" />
                        <path d="M9 9h6" />
                        <path d="M9 15h6" />
                      </svg>
                    )}
                    {item.icon === "guided" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 3v18" />
                        <path d="M3 12h18" />
                        <circle cx="12" cy="12" r="6" />
                        <circle cx="12" cy="12" r="1.8" />
                      </svg>
                    )}
                    {item.icon === "plan" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M5 5h14v14H5z" />
                        <path d="M8 9h8" />
                        <path d="M8 13h5" />
                        <path d="m14.5 15.5 1.5 1.5 3-3" />
                      </svg>
                    )}
                    {item.icon === "fixed" && (
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 5c-1.7 1.2-2.4 3.1-1.9 5.4l1.4 6.7c.3 1.5 2.1 1.9 2.9.6l1-1.7c.8-1.3 2.6-1.3 3.4 0l1 1.7c.8 1.3 2.6.9 2.9-.6l1.4-6.7c.5-2.3-.2-4.2-1.9-5.4-1.1-.8-2.5-.9-3.8-.4l-.7.3c-.8.3-1.6.3-2.4 0l-.7-.3c-1.2-.5-2.6-.4-3.7.4Z" />
                        <path d="m8 11 2 2 4-5" />
                      </svg>
                    )}
                  </span>
                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </div>
                </article>
              ))}
            </div>
            <a class="button button-dark mobile-advantage-cta" href="/richiesta/">Prenota una Visita Ora</a>
          </div>
        </div>
      </section>

      <section class="section section-muted pain-section scroll-reveal" id="situazioni" data-scroll-reveal>
        <div class="section-heading centered">
          <p class="eyebrow teal">Prima della visita</p>
          <h2>
            I segnali che richiedono una <span class="desktop-nowrap">valutazione implantare</span>
          </h2>
          <p>
            Molti dei nostri pazienti vivevano questi stessi disagi prima di affidarsi a noi. Ascoltiamo le tue preoccupazioni per offrirti un percorso sereno e senza sorprese.
          </p>
        </div>

        <div class="pain-grid" aria-label="Situazioni frequenti">
          <article class="pain-card card-reveal" data-card-reveal>
            <span aria-hidden="true">01</span>
            <p>Metti la mano davanti alla bocca quando ridi o parli con gli altri.</p>
          </article>
          <article class="pain-card card-reveal" data-card-reveal>
            <span aria-hidden="true">02</span>
            <p>Rinunci alla carne o ai cibi duri al ristorante per paura che salti un dente o per il dolore.</p>
          </article>
          <article class="pain-card card-reveal" data-card-reveal>
            <span aria-hidden="true">03</span>
            <p>Hai paura di iniziare i lavori perché temi che il prezzo finale raddoppi a sorpresa.</p>
          </article>
          <article class="pain-card card-reveal" data-card-reveal>
            <span aria-hidden="true">04</span>
            <p>Sei terrorizzato dalla poltrona del dentista per via di un trauma passato.</p>
          </article>
        </div>

        <div class="pain-cta">
          <a class="button button-dark" href="/richiesta/">Richiedi una valutazione</a>
        </div>
      </section>

      <section class="section method-section scroll-reveal" id="metodo" data-scroll-reveal>
        <div class="method-inner">
          <div class="method-content">
            <div class="section-heading dark method-heading">
              <p class="eyebrow mint">Siamo dalla tua parte</p>
              <h2>Trasparenza e Tutele Cliniche</h2>
              <p>
                La scelta di riabilitare il sorriso richiede massima chiarezza. Abbiamo eliminato ogni incertezza clinica ed economica formulando quattro garanzie scritte a salvaguardia del paziente.
              </p>
            </div>

            <div class="method-grid">
              {steps.map((step) => (
                <article class="method-card card-reveal" data-card-reveal>
                  <span class="method-number">{step.number}</span>
                  <h3>{step.title}</h3>
                  <p>
                    {step.text}
                    {step.number === "04" && (
                      <>
                        {" Consulta le "}
                        <button class="faq-inline-link" type="button" data-convention-open="dirette">convenzioni dirette</button>
                        {" e le "}
                        <button class="faq-inline-link" type="button" data-convention-open="indirette">convenzioni indirette</button>
                      </>
                    )}
                  </p>
                </article>
              ))}
            </div>
            <a class="button button-primary method-mobile-cta" href="/richiesta/">
              Prenota visita implantologica <span aria-hidden="true">-&gt;</span>
            </a>
          </div>

          <img class="method-dentist" src={dentistCutout} alt="" width="351" height="602" loading="lazy" decoding="async" aria-hidden="true" />
        </div>
      </section>

      <section class="section section-white scroll-reveal" id="recensioni" data-scroll-reveal>
        <div class="section-heading centered">
          <p class="eyebrow teal">Dicono di noi</p>
          <h2>Competenza ed affidabilità</h2>
          <p>Recensioni orientate a percorsi implantari e riabilitazioni.</p>
        </div>

        <div class="testimonial-carousel" data-testimonial-carousel>
          <button class="testimonial-nav testimonial-nav--prev" type="button" aria-label="Recensione precedente" data-testimonial-prev>
            <span aria-hidden="true">‹</span>
          </button>

          <div class="testimonial-viewport">
            <div class="testimonial-track" data-testimonial-track>
              {testimonials.map((item) => (
                <article class="testimonial-card card-reveal" data-testimonial-card data-card-reveal>
                  <header class="testimonial-card__header">
                    <span class="testimonial-initial" aria-hidden="true">{item.initials}</span>
                    <div>
                      <strong>{item.name}</strong>
                      {item.verified && <span class="testimonial-badge">Appuntamento verificato</span>}
                    </div>
                  </header>
                  <div class="stars" aria-label="Cinque stelle">★★★★★</div>
                  <blockquote>{item.quote}</blockquote>
                  <footer class="testimonial-meta">
                    <span>{item.date}</span>
                    <span>{item.doctor}</span>
                    <span>{item.treatment}</span>
                  </footer>
                </article>
              ))}
            </div>
          </div>

          <button class="testimonial-nav testimonial-nav--next" type="button" aria-label="Recensione successiva" data-testimonial-next>
            <span aria-hidden="true">›</span>
          </button>

          <button class="testimonial-more" type="button" data-testimonial-more>guarda altre nostre recensioni</button>
        </div>
      </section>

      <section class="section section-white team-section scroll-reveal" id="chi-siamo" data-scroll-reveal>
        <div class="section-heading split team-heading">
          <div>
            <p class="eyebrow teal">Chi siamo</p>
            <h2>Il team che valuta il tuo caso</h2>
          </div>
          <p>
            Professionisti dello Studio Dentistico Sorriso & Salute seguono diagnosi, piano clinico e controlli del percorso implantare.
          </p>
        </div>

        <div class="team-grid" aria-label="Equipe Studio Dentistico Sorriso & Salute">
          {team.map((member) => (
            <article class="team-card card-reveal" data-card-reveal>
              <img src={member.image} alt={`${member.name} - ${member.role}`} loading="lazy" />
              <div>
                <h3>{member.name}</h3>
                <p>{member.role}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section section-muted scroll-reveal" id="faq" data-scroll-reveal>
        <div class="faq-wrap">
          <div class="section-heading">
            <p class="eyebrow teal">Domande frequenti</p>
            <h2>Dubbi sugli impianti?</h2>
            <p>Risposte su diagnosi, tempi, costi e fattibilità del percorso implantare.</p>
          </div>

          <div class="faq-list">
            {faqs.map((item, index) => (
              <details class="faq-item card-reveal" open={index === 0} data-card-reveal>
                <summary>
                  <span>{item.q}</span>
                  <span class="faq-icon" aria-hidden="true">+</span>
                </summary>
                <p>{item.a}</p>
              </details>
            ))}
            <details class="faq-item card-reveal" data-card-reveal>
              <summary>
                <span>Avete convenzioni dirette e indirette?</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class="faq-rich">
                <p>
                  Sì, lo studio collabora con fondi sanitari, mutue, assicurazioni e network sia in forma diretta che indiretta.
                  Per capire se la tua copertura può essere utilizzata, consulta l'elenco delle
                  <button class="faq-inline-link" type="button" data-convention-open="dirette">convenzioni dirette</button>
                  e delle
                  <button class="faq-inline-link" type="button" data-convention-open="indirette">convenzioni indirette</button>,
                  oppure chiedilo durante la valutazione.
                </p>
              </div>
            </details>
          </div>
        </div>
      </section>

      <section class="contact-section scroll-reveal" id="contatto" data-scroll-reveal>
        <div class="contact-copy">
          <p class="eyebrow teal">Inizia il tuo percorso con noi</p>
          <h2>Il primo passo per tornare a masticare con più sicurezza</h2>
          <p>
            Raccontaci la tua situazione in pochi passaggi: denti mancanti, difficoltà nella masticazione o protesi instabile. Lo studio valuterà il tuo caso e ti indicherà la soluzione implantologica più adatta.
          </p>
        </div>

        <div class="contact-card card-reveal" data-card-reveal>
          <div>
            <span>Modulo unico</span>
            <h3>Compila la richiesta in pochi passaggi.</h3>
            <p>
              Il percorso raccoglie problema, obiettivo, preferenza di data e recapiti, poi prepara la richiesta da inviare allo studio.
            </p>
          </div>
          <a class="button button-dark" href="/richiesta/">
            Voglio capire se posso mettere gli impianti
          </a>
