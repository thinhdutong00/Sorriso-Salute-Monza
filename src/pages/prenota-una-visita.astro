---
import BrandPalette from "../components/BrandPalette.astro";
import FaviconLinks from "../components/FaviconLinks.astro";
import GoogleAdsTracking from "../components/GoogleAdsTracking.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="0; url=/richiesta-generale/" />
    <link rel="canonical" href="https://sorrisoesalutemonza.it/richiesta-generale/" />
    <title>Prenota una visita - Studio Dentistico Sorriso & Salute</title>
    <FaviconLinks />
    <GoogleAdsTracking />
    <BrandPalette />
  </head>
  <body class="brand-palette">
    <main style="min-height:100vh;display:grid;place-items:center;font-family:system-ui,sans-serif;text-align:center;padding:24px;background:#ffffff">
      <a href="/richiesta-generale/" style="color:#0E384C;font-weight:800">Vai alla richiesta di prenotazione</a>
    </main>
    <SiteFooter />
  </body>
</html>
