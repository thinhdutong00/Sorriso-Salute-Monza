    const attachWhatsappConversionListener = () => {
      if (googleWindow.__whatsappConversionListenerAttached) return;
      googleWindow.__whatsappConversionListenerAttached = true;

      const whatsappPatterns = ["wa.me", "api.whatsapp.com", "web.whatsapp.com", "whatsapp://"];
      const isWhatsappHref = (href) => {
        const normalizedHref = href.toLowerCase();
        return whatsappPatterns.some((pattern) => normalizedHref.includes(pattern));
      };

      document.addEventListener(
        "click",
        (event) => {
          const trackedEvent = event;
          if (trackedEvent.defaultPrevented || trackedEvent.__whatsappGoogleAdsHandled) return;

          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest("a[href]");
          if (!(link instanceof HTMLAnchorElement)) return;
          if (!isWhatsappHref(link.getAttribute("href") || "")) return;
          if (link.dataset.googleAdsConversion !== "whatsapp-implantologia") return;

          trackedEvent.__whatsappGoogleAdsHandled = true;

          const isModifiedClick =
            event instanceof MouseEvent &&
            (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0);
          const opensNewContext = Boolean(link.target && link.target.toLowerCase() !== "_self");

