---
const whatsappConversionSendTo = import.meta.env.PUBLIC_GOOGLE_ADS_WHATSAPP_SEND_TO ?? "";
---

<!-- Google tag (gtag.js) -->
<script define:vars={{ whatsappConversionSendTo }}>
  (() => {
    const googleAdsId = "AW-18196734570";
    window.dataLayer = window.dataLayer || [];

    function gtag() {
      window.dataLayer.push(arguments);
    }

    window.gtag = window.gtag || gtag;
    window.gtag("js", new Date());
    window.gtag("config", googleAdsId);
    window.gtag("config", "AW-18196734570/niV2CMvlu7wCEOrE8ORD", {
      phone_conversion_number: "039 2022489",
    });

    const loadGoogleAds = () => {
      if (window.__googleAdsLoaded) return;
      window.__googleAdsLoaded = true;
      const script = document.createElement("script");
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtag/js?id=${googleAdsId}`;
      document.head.appendChild(script);
    };

    const installWhatsappConversionTracking = () => {
      if (window.__whatsappAdsTrackingInstalled) return;
      window.__whatsappAdsTrackingInstalled = true;

      const whatsappPatterns = ["wa.me", "api.whatsapp.com", "web.whatsapp.com"];
      const isWhatsappHref = (href) => {
        const normalizedHref = href.toLowerCase();
        return whatsappPatterns.some((pattern) => normalizedHref.includes(pattern));
      };

      document.addEventListener(
        "click",
        (event) => {
          if (event.defaultPrevented) return;
          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest("a[href]");
          if (!(link instanceof HTMLAnchorElement)) return;
          if (!isWhatsappHref(link.getAttribute("href") || "")) return;
          if (!whatsappConversionSendTo || typeof window.gtag !== "function") return;

          const conversionPayload = {
            send_to: whatsappConversionSendTo,
          };
          const opensNewContext = Boolean(link.target && link.target.toLowerCase() !== "_self");
          const isModifiedClick =
            event instanceof MouseEvent &&
            (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0);

          if (opensNewContext || isModifiedClick) {
            window.gtag("event", "conversion", conversionPayload);
            return;
          }

          event.preventDefault();

          let hasNavigated = false;
          const openWhatsapp = () => {
            if (hasNavigated) return;
            hasNavigated = true;
            window.location.href = link.href;
          };

          window.setTimeout(openWhatsapp, 900);
          window.gtag("event", "conversion", {
            ...conversionPayload,
            event_callback: openWhatsapp,
            event_timeout: 800,
          });
        },
        true,
      );
    };

    const scheduleGoogleAds = () => {
      if (window.location.pathname.includes("/thank-you-page")) {
        loadGoogleAds();
        return;
      }

      const loadOnInteraction = () => {
        cleanup();
        loadGoogleAds();
      };

      const cleanup = () => {
        window.removeEventListener("pointerdown", loadOnInteraction);
        window.removeEventListener("keydown", loadOnInteraction);
        window.removeEventListener("scroll", loadOnInteraction);
        window.removeEventListener("touchstart", loadOnInteraction);
      };

      window.addEventListener("pointerdown", loadOnInteraction, { once: true, passive: true });
      window.addEventListener("keydown", loadOnInteraction, { once: true });
      window.addEventListener("scroll", loadOnInteraction, { once: true, passive: true });
      window.addEventListener("touchstart", loadOnInteraction, { once: true, passive: true });
      window.setTimeout(loadGoogleAds, 8000);
    };

    if (document.readyState === "complete") {
      scheduleGoogleAds();
    } else {
      window.addEventListener("load", scheduleGoogleAds, { once: true });
    }

    installWhatsappConversionTracking();
  })();
</script>
