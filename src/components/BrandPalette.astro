<script is:inline>
  (() => {
    const teamSlidersSelector = ".elementor-element-4954a511, .elementor-element-b46e7c4";

    const normalizeText = (value) => value.replace(/\u00a0/g, " ").replace(/\s+/g, " ").trim();

    const getTeamCopy = (container) => {
      const links = Array.from(container.querySelectorAll("a")).map((link) => ({
        href: link.getAttribute("href") || "#",
        label: normalizeText(link.textContent || link.href || ""),
      })).filter((link) => link.label);

      const linkLabels = new Set(links.map((link) => link.label.toLowerCase()));
      const clone = container.cloneNode(true);
      clone.querySelectorAll("br").forEach((breakNode) => breakNode.replaceWith("\n"));

      const lines = (clone.textContent || "")
        .replace(/\u00a0/g, " ")
        .split(/\n+/)
        .map(normalizeText)
        .filter(Boolean);

      const name = lines.shift() || "";
      const roleLines = [];
      const detailLines = [];
      let isDetail = false;

      lines.forEach((line) => {
        const normalizedLine = line.toLowerCase();
        if (/^si occupa\b/i.test(line) || /^www\./i.test(line) || /^https?:\/\//i.test(line)) {
          isDetail = true;
        }

        if (isDetail) {
          if (!linkLabels.has(normalizedLine)) detailLines.push(line);
        } else {
          roleLines.push(line);
        }
      });

      return {
        name,
        role: roleLines.join(" "),
        detail: detailLines.join(" "),
        links,
      };
    };

    const createTextElement = (tagName, className, text) => {
      const element = document.createElement(tagName);
      element.className = className;
      element.textContent = text;
      return element;
    };

    const enhanceCard = (card) => {
      const inner = card.querySelector(":scope > .e-con-inner");
      if (!inner || inner.dataset.brandTeamFlip === "true") return;

      const imageWidget = inner.querySelector(".elementor-widget-image");
      const textWidget = inner.querySelector(".elementor-widget-text-editor");
      const textContainer = textWidget?.querySelector(".elementor-widget-container");
      if (!imageWidget || !textWidget || !textContainer) return;

      const copy = getTeamCopy(textContainer);
      if (!copy.name) return;

      inner.dataset.brandTeamFlip = "true";
      inner.classList.add("brand-team-card");
      textWidget.classList.add("brand-team-card__copy-ready");

      const front = document.createElement("div");
      front.className = "brand-team-card__front-copy";
      front.append(createTextElement("span", "brand-team-card__name", copy.name));
      if (copy.role) front.append(createTextElement("span", "brand-team-card__role", copy.role));

      const hasBack = Boolean(copy.detail || copy.links.length);
      const nextContent = [front];

      if (hasBack) {
        inner.classList.add("brand-team-card--has-back");
        inner.setAttribute("tabindex", "0");
        inner.setAttribute("aria-label", `${copy.name}. ${copy.role || ""}. Mostra dettagli al passaggio del mouse.`);

        const back = document.createElement("div");
        back.className = "brand-team-card__back-copy";
        back.append(createTextElement("span", "brand-team-card__back-label", "Area di attività"));
        if (copy.detail) back.append(createTextElement("p", "brand-team-card__back-text", copy.detail));

        copy.links.forEach((link) => {
          const anchor = document.createElement("a");
          anchor.className = "brand-team-card__back-link";
          anchor.href = link.href;
          anchor.textContent = link.label;
          back.append(anchor);
        });

        nextContent.push(back);
      }

      textContainer.replaceChildren(...nextContent);
    };

    const enhanceTeamCards = () => {
      document.querySelectorAll(teamSlidersSelector).forEach((slider) => {
        slider.querySelectorAll(".ekit-widget-area-container > .elementor > .e-con").forEach(enhanceCard);
      });
    };

    const run = () => {
      enhanceTeamCards();
      window.setTimeout(enhanceTeamCards, 600);
      window.setTimeout(enhanceTeamCards, 1600);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", run, { once: true });
    } else {
      run();
    }

    document.addEventListener("astro:page-load", run);
  })();
</script>
