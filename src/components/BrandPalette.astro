<script is:inline>
  (() => {
    const teamSlidersSelector = ".elementor-element-4954a511, .elementor-element-b46e7c4";
    const reviewSliderSelector = ".elementor-element-a5f5b74";
    const reviewToggleThreshold = 120;
    const reviewMaxCollapsedLines = 4;

    const normalizeText = (value) => value.replace(/\u00a0/g, " ").replace(/\s+/g, " ").trim();

    const getTeamCopy = (container) => {
      const links = Array.from(container.querySelectorAll("a")).map((link) => ({
        href: link.getAttribute("href") || "#",
        label: normalizeText(link.textContent || link.href || ""),
      })).filter((link) => link.label);

      const linkLabels = new Set(links.map((link) => link.label.toLowerCase()));
      const clone = container.cloneNode(true);
      clone.querySelectorAll("br").forEach((breakNode) => breakNode.replaceWith("\n"));

      const lines = (clone.textContent || "")
        .replace(/\u00a0/g, " ")
        .split(/\n+/)
        .map(normalizeText)
        .filter(Boolean);

      const name = lines.shift() || "";
      const roleLines = [];
      const detailLines = [];
      let isDetail = false;

      lines.forEach((line) => {
        const normalizedLine = line.toLowerCase();
        if (/^si occupa\b/i.test(line) || /^www\./i.test(line) || /^https?:\/\//i.test(line)) {
          isDetail = true;
        }

        if (isDetail) {
          if (!linkLabels.has(normalizedLine)) detailLines.push(line);
        } else {
          roleLines.push(line);
        }
      });

      return {
        name,
        role: roleLines.join(" "),
        detail: detailLines.join(" "),
        links,
      };
    };

    const createTextElement = (tagName, className, text) => {
      const element = document.createElement(tagName);
      element.className = className;
      element.textContent = text;
      return element;
    };

    const enhanceCard = (card) => {
      const inner = card.querySelector(":scope > .e-con-inner");
      if (!inner || inner.dataset.brandTeamFlip === "true") return;

      const imageWidget = inner.querySelector(".elementor-widget-image");
      const textWidget = inner.querySelector(".elementor-widget-text-editor");
      const textContainer = textWidget?.querySelector(".elementor-widget-container");
      if (!imageWidget || !textWidget || !textContainer) return;

      const copy = getTeamCopy(textContainer);
      if (!copy.name) return;

      inner.dataset.brandTeamFlip = "true";
      inner.classList.add("brand-team-card");
      textWidget.classList.add("brand-team-card__copy-ready");

      const front = document.createElement("div");
      front.className = "brand-team-card__front-copy";
      front.append(createTextElement("span", "brand-team-card__name", copy.name));
      if (copy.role) front.append(createTextElement("span", "brand-team-card__role", copy.role));

      const hasBack = Boolean(copy.detail || copy.links.length);
      const nextContent = [front];

      if (hasBack) {
        inner.classList.add("brand-team-card--has-back");
        inner.setAttribute("tabindex", "0");
        inner.setAttribute("aria-label", `${copy.name}. ${copy.role || ""}. Mostra dettagli al passaggio del mouse.`);

        const back = document.createElement("div");
        back.className = "brand-team-card__back-copy";
        back.append(createTextElement("span", "brand-team-card__back-label", "Area di attività"));
        if (copy.detail) back.append(createTextElement("p", "brand-team-card__back-text", copy.detail));

        copy.links.forEach((link) => {
          const anchor = document.createElement("a");
          anchor.className = "brand-team-card__back-link";
          anchor.href = link.href;
          anchor.textContent = link.label;
          back.append(anchor);
        });

        nextContent.push(back);
      }

      textContainer.replaceChildren(...nextContent);
    };

    const enhanceTeamCards = () => {
      document.querySelectorAll(teamSlidersSelector).forEach((slider) => {
        slider.querySelectorAll(".ekit-widget-area-container > .elementor > .e-con").forEach(enhanceCard);
      });
    };

    const syncReviewSwiper = (card) => {
      const slider = card.closest(".elementskit-testimonial-slider");
      const swiperElement = card.closest(".swiper");
      const swiper = swiperElement?.swiper;
      const isExpanded = Boolean(slider?.querySelector(".brand-review-expanded"));
      slider?.classList.toggle("brand-review-slider-expanded", isExpanded);
      if (!swiper) return;

      window.requestAnimationFrame(() => {
        const wrapper = swiperElement.querySelector(".swiper-wrapper");
        const cardHeight = card.getBoundingClientRect().height;
        swiperElement.style.height = `${cardHeight}px`;
        if (wrapper) wrapper.style.height = `${cardHeight}px`;

        swiper.updateSize?.();
        swiper.update?.();
        swiper.updateSlides?.();
      });
    };

    const collapseReviewCard = (card) => {
      card.classList.remove("brand-review-expanded");
      card.classList.add("brand-review-collapsed");
      renderReviewText(card, false);
      syncReviewSwiper(card);
    };

    const getCollapsedReviewText = (paragraph, text) => {
      const words = text.split(/\s+/).filter(Boolean);

      const renderCandidate = (wordCount) => {
        const candidate = words.slice(0, wordCount).join(" ").replace(/[.,;:!?]+$/u, "");
        paragraph.textContent = candidate;
        const textNode = paragraph.firstChild;
        if (!textNode) return true;

        const range = document.createRange();
        range.selectNodeContents(textNode);
        const lineTops = new Set(Array.from(range.getClientRects(), (rect) => Math.round(rect.top * 10) / 10));
        return lineTops.size <= reviewMaxCollapsedLines;
      };

      let lowerBound = 1;
      let upperBound = words.length;
      let bestWordCount = 1;

      while (lowerBound <= upperBound) {
        const candidateWordCount = Math.floor((lowerBound + upperBound) / 2);
        if (renderCandidate(candidateWordCount)) {
          bestWordCount = candidateWordCount;
          lowerBound = candidateWordCount + 1;
        } else {
          upperBound = candidateWordCount - 1;
        }
      }

      return words.slice(0, bestWordCount).join(" ").replace(/[.,;:!?]+$/u, "");
    };

    const renderReviewText = (card, isExpanded) => {
      const paragraph = card.querySelector(".elementskit-commentor-content p");
      const button = card.querySelector(".brand-review-toggle");
      const fullText = card.dataset.brandReviewFullText || "";
      if (!paragraph || !button || !fullText) return;

      button.textContent = isExpanded ? "leggi di meno −" : "leggi di più +";
      const reviewText = isExpanded ? fullText : getCollapsedReviewText(paragraph, fullText);
      paragraph.textContent = reviewText;
      if (isExpanded) paragraph.append("\u00a0");
      paragraph.append(button);

      button.setAttribute("aria-expanded", isExpanded ? "true" : "false");
      const authorName = normalizeText(card.querySelector(".elementskit-author-name")?.textContent || "questo paziente");
      button.setAttribute("aria-label", `${isExpanded ? "Riduci" : "Espandi"} la recensione di ${authorName}`);
    };

    const enhanceReviewCard = (card) => {
      if (card.dataset.brandReviewToggle === "true") {
        if (card.classList.contains("brand-review-has-toggle") && card.classList.contains("brand-review-collapsed")) {
          renderReviewText(card, false);
        }
        return;
      }

      const content = card.querySelector(".elementskit-commentor-content");
      const paragraph = content?.querySelector("p");
      if (!content || !paragraph) return;

      const author = card.querySelector(".elementskit-author-name");
      const authorName = normalizeText(author?.textContent || "");
      const avatar = card.querySelector(".elementskit-commentor-image");
      const authorDescription = card.querySelector(".elementskit-author-des");
      if (avatar && authorName) {
        avatar.classList.add("brand-review-avatar-initial");
        avatar.dataset.reviewInitial = authorName.charAt(0).toUpperCase();
        avatar.setAttribute("aria-hidden", "true");
      }
      if (authorDescription) authorDescription.textContent = "Paziente verificato";

      card.dataset.brandReviewToggle = "true";
      card.classList.add("brand-review-collapsed");

      const text = normalizeText(paragraph.textContent || "");
      if (text.length <= reviewToggleThreshold) return;

      card.dataset.brandReviewFullText = text;
      card.classList.add("brand-review-has-toggle");

      const button = document.createElement("button");
      button.type = "button";
      button.className = "brand-review-toggle";
      button.textContent = "leggi di più +";
      button.setAttribute("aria-expanded", "false");
      button.setAttribute("aria-label", `Espandi la recensione di ${authorName || "questo paziente"}`);

      paragraph.append(button);
      renderReviewText(card, false);
    };

    const enhanceReviewCards = () => {
      document.querySelectorAll(reviewSliderSelector).forEach((sliderRoot) => {
        sliderRoot.querySelectorAll(".elementskit-single-testimonial-slider").forEach(enhanceReviewCard);
        const activeCard = sliderRoot.querySelector(".swiper-slide-active .elementskit-single-testimonial-slider");
        if (activeCard) syncReviewSwiper(activeCard);
      });
    };

    const bindReviewToggleEvents = () => {
      document.querySelectorAll(reviewSliderSelector).forEach((sliderRoot) => {
        if (sliderRoot.dataset.brandReviewEvents === "true") return;

        sliderRoot.dataset.brandReviewEvents = "true";
        sliderRoot.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;

          const button = event.target.closest(".brand-review-toggle");
          const card = button?.closest(".elementskit-single-testimonial-slider");
          if (!button || !card || !sliderRoot.contains(card)) return;

          event.preventDefault();
          event.stopPropagation();

          const shouldExpand = !card.classList.contains("brand-review-expanded");
          if (shouldExpand) {
            card.closest(".elementskit-testimonial-slider")?.querySelectorAll(".brand-review-expanded").forEach((expandedCard) => {
              if (expandedCard !== card) collapseReviewCard(expandedCard);
            });
            card.classList.add("brand-review-expanded");
            card.classList.remove("brand-review-collapsed");
            renderReviewText(card, true);
          } else {
            collapseReviewCard(card);
          }

          syncReviewSwiper(card);
        });
      });
    };

    const bindReviewResize = () => {
      if (document.documentElement.dataset.brandReviewResize === "true") return;

      document.documentElement.dataset.brandReviewResize = "true";
      let resizeTimer;
      window.addEventListener("resize", () => {
        window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          enhanceReviewCards();
          document.querySelectorAll(`${reviewSliderSelector} .swiper-slide-active .elementskit-single-testimonial-slider`).forEach(syncReviewSwiper);
        }, 150);
      });
    };

    const run = () => {
      enhanceTeamCards();
      enhanceReviewCards();
      bindReviewToggleEvents();
      bindReviewResize();
      window.setTimeout(enhanceTeamCards, 600);
      window.setTimeout(enhanceReviewCards, 600);
      window.setTimeout(enhanceTeamCards, 1600);
      window.setTimeout(enhanceReviewCards, 1600);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", run, { once: true });
    } else {
      run();
    }

    document.addEventListener("astro:page-load", run);
  })();
</script>
