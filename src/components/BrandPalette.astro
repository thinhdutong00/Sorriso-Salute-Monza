      body.brand-palette.home.mirror-header-over-hero .ekit-template-content-header,
      body.brand-palette.home.mirror-header-over-hero .ekit-template-content-header .elementor-element.elementor-element-6f3d2e5:not(.elementor-motion-effects-element-type-background),
      body.brand-palette.home.mirror-header-over-hero .ekit-template-content-header .elementor-element.elementor-element-6f3d2e5 > .elementor-motion-effects-container > .elementor-motion-effects-layer {
        background: rgba(255, 255, 255, 0.96) !important;
        background-color: rgba(255, 255, 255, 0.96) !important;
        border-color: rgba(191, 197, 210, 0.72) !important;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.1) !important;
        backdrop-filter: blur(14px) !important;
