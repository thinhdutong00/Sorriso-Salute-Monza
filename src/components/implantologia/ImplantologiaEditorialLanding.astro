---
import "../../styles/global.css";
import FaviconLinks from "../FaviconLinks.astro";
import GoogleAdsTracking from "../GoogleAdsTracking.astro";
import SiteFooter from "../SiteFooter.astro";
import type { ImplantologiaEditorialPage } from "../../data/implantologiaEditorialPages";
import ImplantologiaAttribution from "./ImplantologiaAttribution.astro";
import ImplantologiaHeader from "./ImplantologiaHeader.astro";

interface Props {
  page: ImplantologiaEditorialPage;
}

const { page } = Astro.props;
const canonical = `https://sorrisoesalutemonza.it/implantologia/${page.slug}/`;
const absoluteHeroImage = `https://sorrisoesalutemonza.it${page.heroImage}`;
const firstSections = page.sections.slice(0, 2);
const remainingSections = page.sections.slice(2);
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://sorrisoesalutemonza.it/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Percorso implantologico",
      item: "https://sorrisoesalutemonza.it/implantologia/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: page.h1,
      item: canonical,
    },
  ],
};
const faqSchema = {
  "@type": "FAQPage",
  mainEntity: page.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [breadcrumbSchema, faqSchema],
};
const ctaHref = "/richiesta/";
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{page.title}</title>
    <meta name="description" content={page.metaDescription} />
    <meta name="theme-color" content="#0E384C" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteHeroImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <FaviconLinks />
    <GoogleAdsTracking />
  </head>
  <body class="implant-landing implant-editorial-page">
    <ImplantologiaAttribution serviceInterest={page.serviceInterest} isLanding />
    <ImplantologiaHeader />

    <main class="implant-editorial">
      <section class="implant-editorial__hero" id="panoramica" aria-labelledby="implant-editorial-title">
        <div class="implant-editorial__container">
          <nav class="implant-editorial__breadcrumb" aria-label="Breadcrumb">
            <ol>
              <li><a href="/">Home</a></li>
              <li><a href="/implantologia/">Percorso implantologico</a></li>
              <li aria-current="page">{page.h1}</li>
            </ol>
          </nav>

          <div class="implant-editorial__hero-grid">
            <div class="implant-editorial__hero-copy">
              <p class="implant-editorial__kicker implant-editorial__kicker--light">Implantologia a Monza · Sorriso &amp; Salute</p>
              <h1 id="implant-editorial-title">{page.h1}</h1>
              <p class="implant-editorial__hero-intro">{page.heroIntro}</p>
              <p class="implant-editorial__clinical-note">
                La soluzione viene definita dopo la visita: indicazioni, tempi e modalità variano in base al caso.
              </p>
              <div class="implant-editorial__actions">
                <a class="implant-editorial__button implant-editorial__button--accent" href={ctaHref}>
                  Richiedi una valutazione implantologica
                </a>
                <a class="implant-editorial__button implant-editorial__button--ghost" href="tel:+390392022489">
                  Chiama lo studio
                </a>
              </div>
            </div>

            <figure class="implant-editorial__hero-visual">
              <div class="implant-editorial__hero-orbit" aria-hidden="true"></div>
              <picture>
                <source
                  type={page.heroSourceType}
                  srcset={page.heroSrcSet}
                  sizes="(max-width: 767px) calc(100vw - 84px), (max-width: 1100px) 44vw, 520px"
                />
                <img
                  src={page.heroImage}
                  alt={page.heroAlt}
                  width={page.heroWidth}
                  height={page.heroHeight}
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </picture>
              <figcaption>Valutazione clinica e progettazione implantare e protesica individuale</figcaption>
            </figure>
          </div>
        </div>
      </section>

      <section class="implant-editorial__section implant-editorial__recognition" aria-labelledby="recognition-title">
        <div class="implant-editorial__container implant-editorial__split">
          <div class="implant-editorial__heading">
            <p class="implant-editorial__kicker">La domanda da cui partire</p>
            <h2 id="recognition-title">{page.recognitionTitle}</h2>
            <p>{page.recognitionIntro}</p>
          </div>
          <ul class="implant-editorial__recognition-list">
            {page.recognitionItems.map((item) => (
              <li>
                <span aria-hidden="true">✓</span>
                <p>{item}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      {firstSections.map((section) => (
        <section
          class:list={[
            "implant-editorial__section",
            `implant-editorial__section--${section.tone ?? "plain"}`,
          ]}
          id={section.id}
          aria-labelledby={`${section.id}-title`}
        >
          <div class="implant-editorial__container">
            <div class="implant-editorial__section-heading">
              <p class:list={["implant-editorial__kicker", section.tone === "dark" && "implant-editorial__kicker--light"]}>
                {section.kicker}
              </p>
              <h2 id={`${section.id}-title`}>{section.title}</h2>
              {section.intro && <p>{section.intro}</p>}
            </div>

            {section.paragraphs && (
              <div class="implant-editorial__prose">
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            )}

            {section.bullets && (
              <ul class="implant-editorial__bullet-list">
                {section.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}

            {section.cards && (
              <div class="implant-editorial__cards">
                {section.cards.map((card) => (
                  <article class="implant-editorial__card">
                    <h3>{card.title}</h3>
                    <p>{card.text}</p>
                  </article>
                ))}
              </div>
            )}
          </div>
        </section>
      ))}

      <section class="implant-editorial__cta-strip" aria-labelledby="editorial-mid-cta-title">
        <div class="implant-editorial__container implant-editorial__cta-strip-inner">
          <div>
            <p class="implant-editorial__kicker implant-editorial__kicker--light">Un primo passo concreto</p>
            <h2 id="editorial-mid-cta-title">Trasforma i dubbi in una valutazione individuale</h2>
            <p>Il modulo già in uso sul sito raccoglie la tua richiesta e le preferenze per essere ricontattato dallo studio.</p>
          </div>
          <a class="implant-editorial__button implant-editorial__button--accent" href={ctaHref}>
            Richiedi una valutazione implantologica
          </a>
        </div>
      </section>

      {page.timeline && (
        <section class="implant-editorial__section implant-editorial__section--paper" id="prima-durante-dopo" aria-labelledby="timeline-title">
          <div class="implant-editorial__container">
            <div class="implant-editorial__section-heading">
              <p class="implant-editorial__kicker">{page.timeline.kicker}</p>
              <h2 id="timeline-title">{page.timeline.title}</h2>
              <p>{page.timeline.intro}</p>
            </div>
            <ol class="implant-editorial__timeline">
              {page.timeline.steps.map((step) => (
                <li>
                  <span>{step.number}</span>
                  <div>
                    <h3>{step.title}</h3>
                    <p>{step.text}</p>
                  </div>
                </li>
              ))}
            </ol>
            <div class="implant-editorial__timeline-cta">
              <p>La visita permette di ordinare questi passaggi in base alla tua situazione.</p>
              <a class="implant-editorial__text-link" href={ctaHref}>Inizia dalla richiesta di valutazione <span aria-hidden="true">→</span></a>
            </div>
          </div>
        </section>
      )}

      {remainingSections.map((section) => (
        <section
          class:list={[
            "implant-editorial__section",
            `implant-editorial__section--${section.tone ?? "plain"}`,
          ]}
          id={section.id}
          aria-labelledby={`${section.id}-title`}
        >
          <div class="implant-editorial__container">
            <div class="implant-editorial__section-heading">
              <p class:list={["implant-editorial__kicker", section.tone === "dark" && "implant-editorial__kicker--light"]}>
                {section.kicker}
              </p>
              <h2 id={`${section.id}-title`}>{section.title}</h2>
              {section.intro && <p>{section.intro}</p>}
            </div>

            {section.paragraphs && (
              <div class="implant-editorial__prose">
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            )}

            {section.bullets && (
              <ul class="implant-editorial__bullet-list">
                {section.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}

            {section.cards && (
              <div class="implant-editorial__cards">
                {section.cards.map((card) => (
                  <article class="implant-editorial__card">
                    <h3>{card.title}</h3>
                    <p>{card.text}</p>
                  </article>
                ))}
              </div>
            )}
          </div>
        </section>
      ))}

      <section class="implant-editorial__section implant-editorial__cost" id="preventivo" aria-labelledby="cost-title">
        <div class="implant-editorial__container implant-editorial__split">
          <div class="implant-editorial__heading">
            <p class="implant-editorial__kicker">Trasparenza prima di decidere</p>
            <h2 id="cost-title">Che cosa determina il preventivo</h2>
            <p>
              Non esiste un importo corretto per ogni situazione. Il preventivo viene formulato dopo aver definito il
              progetto clinico e protesico.
            </p>
          </div>
          <ul class="implant-editorial__factor-list">
            {page.costFactors.map((factor, index) => (
              <li><span>{String(index + 1).padStart(2, "0")}</span><p>{factor}</p></li>
            ))}
          </ul>
        </div>
      </section>

      <section class="implant-editorial__section implant-editorial__section--paper" id="approfondisci" aria-labelledby="related-title">
        <div class="implant-editorial__container">
          <div class="implant-editorial__section-heading">
            <p class="implant-editorial__kicker">Approfondisci il tuo caso</p>
            <h2 id="related-title">Soluzioni e passaggi collegati</h2>
            <p>Consulta le pagine utili per capire differenze, possibilità e fasi del percorso.</p>
          </div>
          <div class="implant-editorial__related-grid">
            {page.relatedLinks.map((link) => (
              <a href={link.href}>
                <span>
                  <strong>{link.label}</strong>
                  <small>{link.text}</small>
                </span>
                <b aria-hidden="true">→</b>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="implant-editorial__section" id="faq" aria-labelledby="faq-title">
        <div class="implant-editorial__container implant-editorial__faq-layout">
          <div class="implant-editorial__heading implant-editorial__faq-heading">
            <p class="implant-editorial__kicker">Domande frequenti</p>
            <h2 id="faq-title">I dubbi da chiarire prima di scegliere</h2>
            <p>Le risposte sono generali: la valutazione serve a riferirle alla situazione individuale.</p>
          </div>
          <div class="implant-editorial__faqs">
            {page.faqs.map((faq, index) => (
              <details open={index === 0}>
                <summary>{faq.question}<span aria-hidden="true">+</span></summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <aside class="implant-editorial__information-note" aria-label="Nota informativa">
        <div class="implant-editorial__container">
          <p>Le informazioni presenti sono di carattere generale e non sostituiscono una valutazione odontoiatrica individuale.</p>
        </div>
      </aside>

      <section class="implant-editorial__final-cta" aria-labelledby="final-cta-title">
        <div class="implant-editorial__container implant-editorial__final-cta-inner">
          <p class="implant-editorial__kicker implant-editorial__kicker--light">Sorriso &amp; Salute · Monza</p>
          <h2 id="final-cta-title">Un percorso chiaro comincia da una valutazione</h2>
          <p>
            Racconta allo studio la tua situazione. La visita permetterà di comprendere le possibilità disponibili,
            i limiti, i passaggi e gli eventuali tempi del tuo caso.
          </p>
          <div class="implant-editorial__actions implant-editorial__actions--center">
            <a class="implant-editorial__button implant-editorial__button--accent" href={ctaHref}>
              Richiedi una valutazione implantologica
            </a>
            <a class="implant-editorial__button implant-editorial__button--ghost" href="tel:+390392022489">
              Chiama lo studio
            </a>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter trackWhatsappAsImplantologia />
  </body>
</html>

<style>
  .implant-editorial {
    --editorial-ink: #0e384c;
    --editorial-ink-dark: #082a38;
    --editorial-teal: #147d83;
    --editorial-mint: #dff5ef;
    --editorial-paper: #f5f2ec;
    --editorial-line: #dce6e5;
    --editorial-body: #405562;
    overflow: clip;
    background: #fff;
    color: var(--editorial-ink);
    font-family: var(--brand-font-family, "Plus Jakarta Sans", Inter, sans-serif);
  }

  .implant-editorial,
  .implant-editorial *,
  .implant-editorial *::before,
  .implant-editorial *::after {
    box-sizing: border-box;
  }

  .implant-editorial__container {
    width: min(1216px, calc(100% - 48px));
    margin-inline: auto;
  }

  .implant-editorial__hero {
    position: relative;
    min-height: min(800px, calc(100svh - var(--implant-home-header-height)));
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 18%, rgba(156, 226, 215, .24), transparent 28%),
      linear-gradient(135deg, #082a38 0%, #0e384c 58%, #155a66 100%);
    color: #fff;
  }

  .implant-editorial__hero::before {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, .12) 1px, transparent 1px);
    background-size: 28px 28px;
    content: "";
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, .8), transparent 82%);
    pointer-events: none;
  }

  .implant-editorial__breadcrumb {
    position: relative;
    z-index: 1;
    padding-top: calc(var(--implant-home-header-height, 86px) + clamp(18px, 2.5vw, 34px));
  }

  .implant-editorial__breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    color: rgba(255, 255, 255, .68);
    font-size: 13px;
    list-style: none;
  }

  .implant-editorial__breadcrumb li { min-width: 0; overflow-wrap: anywhere; }
  .implant-editorial__breadcrumb li:not(:last-child)::after { margin-left: 8px; content: "/"; opacity: .56; }
  .implant-editorial__breadcrumb a { color: inherit; text-decoration: none; }
  .implant-editorial__breadcrumb a:hover { color: #fff; }
  .implant-editorial__breadcrumb a:focus-visible { border-radius: 3px; outline: 2px solid #9ce2d7; outline-offset: 3px; }

  .implant-editorial__hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 650px;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, .92fr);
    align-items: center;
    gap: clamp(48px, 7vw, 104px);
    padding: clamp(56px, 7vw, 102px) 0 clamp(76px, 8vw, 120px);
  }

  .implant-editorial__hero-copy { min-width: 0; }

  .implant-editorial__kicker {
    margin: 0 0 16px;
    color: var(--editorial-teal);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .12em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .implant-editorial__kicker--light { color: #9ce2d7; }

  .implant-editorial__hero h1 {
    max-width: 820px;
    margin: 0;
    color: #fff;
    font-size: clamp(40px, 5.1vw, 76px);
    font-weight: 700;
    letter-spacing: -.045em;
    line-height: .99;
    overflow-wrap: anywhere;
  }

  .implant-editorial__hero-intro {
    max-width: 720px;
    margin: 28px 0 0;
    color: rgba(255, 255, 255, .88);
    font-size: clamp(17px, 1.45vw, 21px);
    line-height: 1.68;
  }

  .implant-editorial__clinical-note {
    max-width: 680px;
    margin: 20px 0 0;
    padding-left: 16px;
    border-left: 2px solid #9ce2d7;
    color: rgba(255, 255, 255, .68);
    font-size: 13px;
    line-height: 1.6;
  }

  .implant-editorial__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .implant-editorial__actions--center { justify-content: center; }

  .implant-editorial__button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    padding: 13px 20px;
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 800;
    line-height: 1.35;
    text-align: center;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .implant-editorial__button:hover { transform: translateY(-2px); }
  .implant-editorial__button:focus-visible { outline: 3px solid rgba(101, 199, 223, .68); outline-offset: 3px; }
  .implant-editorial__button--accent { background: #9ce2d7; color: var(--editorial-ink-dark); box-shadow: 0 14px 34px rgba(0, 0, 0, .18); }
  .implant-editorial__button--accent:hover { background: #b8eee5; }
  .implant-editorial__button--ghost { border-color: rgba(255, 255, 255, .36); background: rgba(255, 255, 255, .08); color: #fff; }
  .implant-editorial__button--ghost:hover { background: rgba(255, 255, 255, .15); }

  .implant-editorial__hero-visual {
    position: relative;
    display: grid;
    min-width: 0;
    place-items: center;
    margin: 0;
    padding: clamp(28px, 4vw, 54px);
    border: 1px solid rgba(255, 255, 255, .18);
    border-radius: 40% 60% 48% 52% / 46% 42% 58% 54%;
    background: rgba(255, 255, 255, .09);
    box-shadow: 0 34px 80px rgba(0, 0, 0, .22);
    isolation: isolate;
  }

  .implant-editorial__hero-orbit {
    position: absolute;
    inset: 8%;
    z-index: -1;
    border: 1px solid rgba(156, 226, 215, .3);
    border-radius: 50%;
  }

  .implant-editorial__hero-visual picture {
    display: block;
    width: min(100%, 520px);
  }

  .implant-editorial__hero-visual img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 430px;
    object-fit: contain;
    filter: drop-shadow(0 24px 24px rgba(0, 0, 0, .22));
  }

  .implant-editorial__hero-visual figcaption {
    position: absolute;
    right: 22px;
    bottom: 20px;
    left: 22px;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, .15);
    border-radius: 14px;
    background: rgba(8, 42, 56, .78);
    color: rgba(255, 255, 255, .82);
    font-size: 11px;
    line-height: 1.5;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  .implant-editorial__section { padding: clamp(76px, 8vw, 118px) 0; }
  .implant-editorial__section--paper { background: var(--editorial-paper); }
  .implant-editorial__section--dark { background: var(--editorial-ink-dark); color: #fff; }

  .implant-editorial__split {
    display: grid;
    grid-template-columns: minmax(260px, .78fr) minmax(0, 1.22fr);
    align-items: start;
    gap: clamp(46px, 8vw, 108px);
  }

  .implant-editorial__heading,
  .implant-editorial__section-heading { min-width: 0; }

  .implant-editorial__heading h2,
  .implant-editorial__section-heading h2,
  .implant-editorial__cta-strip h2,
  .implant-editorial__final-cta h2 {
    margin: 0;
    color: inherit;
    font-size: clamp(31px, 4vw, 54px);
    font-weight: 700;
    letter-spacing: -.04em;
    line-height: 1.06;
    overflow-wrap: anywhere;
  }

  .implant-editorial__heading > p:last-child,
  .implant-editorial__section-heading > p:last-child {
    max-width: 760px;
    margin: 22px 0 0;
    color: var(--editorial-body);
    font-size: 17px;
    line-height: 1.72;
  }

  .implant-editorial__section--dark .implant-editorial__section-heading > p:last-child,
  .implant-editorial__section--dark .implant-editorial__prose p { color: rgba(255, 255, 255, .72); }

  .implant-editorial__section-heading { max-width: 880px; margin-bottom: clamp(38px, 5vw, 62px); }

  .implant-editorial__recognition { background: linear-gradient(180deg, #fff, #f9fbfa); }

  .implant-editorial__recognition-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .implant-editorial__recognition-list li {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    align-items: start;
    gap: 14px;
    padding: 19px 20px;
    border: 1px solid var(--editorial-line);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 10px 28px rgba(8, 42, 56, .05);
  }

  .implant-editorial__recognition-list span {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--editorial-mint);
    color: var(--editorial-teal);
    font-size: 16px;
    font-weight: 800;
  }

  .implant-editorial__recognition-list p { margin: 5px 0 0; color: var(--editorial-body); line-height: 1.6; }

  .implant-editorial__prose {
    display: grid;
    max-width: 880px;
    gap: 16px;
    margin: -20px 0 42px;
  }

  .implant-editorial__prose p { margin: 0; color: var(--editorial-body); font-size: 16px; line-height: 1.75; }

