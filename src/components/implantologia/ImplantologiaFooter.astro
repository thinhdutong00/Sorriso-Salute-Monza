---
const brandLogo = "/assets/brand/sorriso-salute-logo-360.webp";
const footerNavItems = [
  { label: "Dicono di noi", href: "/recensioni-studio-dentistico-monza/" },
  { label: "La Struttura", href: "/struttura-studio-dentistico-monza/" },
  { label: "Convenzioni", href: "/convenzioni-dirette-studio-dentistico-monza/" },
  { label: "Urgenze", href: "/urgenze/" },
  { label: "Chiama in studio: 039 2022489", href: "tel:+390392022489" },
];
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href="/" aria-label="Studio Dentistico Sorriso & Salute">
        <img
          class="brand-logo"
          src={brandLogo}
          alt="Studio Dentistico Sorriso & Salute"
          width="360"
          height="87"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p>Studio Dentistico Sorriso & Salute a Monza, con servizi odontoiatrici e percorsi dedicati all'implantologia.</p>
    </div>
    <div>
      <h3>Esplora</h3>
      {footerNavItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/privacy-policy/">Privacy Policy</a>
      <a href="/cookie-policy/">Cookie Policy</a>
    </div>
    <div>
      <h3>Contatti</h3>
      <a href="tel:+390392022489">Telefono: 039 2022489</a>
      <a
        href="https://wa.me/393892490181"
        target="_blank"
        rel="noreferrer"
        data-google-ads-conversion="whatsapp-implantologia"
      >WhatsApp: +39 389 2490181</a>
      <a href="mailto:info@sorrisoesalute.it">Email: info@sorrisoesalute.it</a>
      <span>Sede: Via Gaslini, 1 — 20090 Monza / 20900 Monza (MB)</span>
    </div>
    <div>
      <h3>Studio</h3>
      <span>Studio Dentistico Sorriso & Salute</span>
      <span>Sorriso & Salute S.r.l.</span>
      <span>P. IVA: 03845830961</span>
      <span>Direttore Sanitario: Dott.ssa Maria Isabel Pareja Carrillo — Odontoiatra</span>
      <span>Titolare e Amministratore: Gianni Focarelli</span>
      <span>Orari: lunedì–venerdì, 9:00–12:30 e 14:00–19:00</span>
    </div>
  </div>
  <div class="footer-bottom">
    <span>Autorizzazione sanitaria n. 2014/11</span>
    <span>Pubblicità conforme art. 1 della legge di bilancio 2019 (30/12/2018 n. 145)</span>
  </div>
</footer>
