---
import "../../styles/global.css";
import FaviconLinks from "../FaviconLinks.astro";
import GoogleAdsTracking from "../GoogleAdsTracking.astro";
import SiteFooter from "../SiteFooter.astro";
import type { ImplantologiaPage } from "../../data/implantologiaPages";
import { implantologiaPages } from "../../data/implantologiaPages";
import ImplantologiaAnamnesiForm from "./ImpiantoSingoloAnamnesiForm.astro";
import ImplantologiaHeader from "./ImplantologiaHeader.astro";
import ImplantologiaReviews from "./ImplantologiaReviews.astro";

interface Props {
  page: ImplantologiaPage;
}

const { page } = Astro.props;
const canonical = `https://sorrisoesalutemonza.it/implantologia/${page.slug}/`;

const methodCards = [
  {
    number: "01",
    title: "Valutazione clinica",
    text: "Partiamo da ciò che non funziona oggi e osserviamo denti, tessuti e funzione.",
  },
  {
    number: "02",
    title: "Spiegazione delle opzioni",
    text: "Confrontiamo le strade realmente percorribili, compresi limiti e possibili alternative.",
  },
  {
    number: "03",
    title: "Piano personalizzato",
    text: "Se il trattamento è indicato, il progetto viene costruito sulla situazione del singolo paziente.",
  },
  {
    number: "04",
    title: "Tempi e passaggi chiari",
    text: "Condividiamo una sequenza comprensibile, dagli eventuali esami fino ai controlli.",
  },
];

const processSteps = [
  {
    number: "01",
    title: "Capire il problema",
    text: "Ascoltiamo cosa non funziona oggi: dente mancante, protesi mobile, difficoltà a masticare o bisogno di maggiore stabilità.",
  },
  {
    number: "02",
    title: "Valutare le possibilità",
    text: "Durante la visita lo studio valuta la situazione e spiega quali opzioni implantologiche possono essere considerate.",
  },
  {
    number: "03",
    title: "Costruire il percorso",
    text: "Se il trattamento è indicato, viene definito un piano con tempi, passaggi e controlli.",
  },
];

const visitChecks = [
  "Situazione dei denti e delle gengive",
  "Stabilità della protesi o del dente",
  "Funzione masticatoria",
  "Eventuali esami necessari",
  "Opzioni di trattamento",
  "Tempi e passaggi",
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{page.title}</title>
    <meta name="description" content={page.metaDescription} />
    <meta name="theme-color" content="#0E384C" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`https://sorrisoesalutemonza.it${page.heroImage}`} />
    <FaviconLinks />
    <GoogleAdsTracking />
  </head>
  <body class="implant-landing">
    <ImplantologiaHeader />

    <main>
      <section class="implant-hero" id="panoramica" aria-labelledby="implant-hero-title">
        <div class="implant-container implant-hero__grid">
          <div class="implant-hero__copy">
            <p class="implant-kicker">Implantologia a Monza · Sorriso &amp; Salute</p>
            <h1 id="implant-hero-title">
              <span>{page.heroTitleFirst}</span>
              <span>{page.heroTitleAccent}</span>
            </h1>
            <p class="implant-hero__lead">{page.heroIntro}</p>
            <p class="implant-clinical-note">
              Il piano viene definito dopo valutazione clinica. Le soluzioni possibili dipendono dalla situazione del
              singolo paziente.
            </p>
            <div class="implant-actions">
              <a class="implant-button implant-button--primary" href="#prenota">Inizia la valutazione</a>
              <a
                class="implant-button implant-button--whatsapp"
                href="https://wa.me/393892490181"
                target="_blank"
                rel="noopener noreferrer"
                data-google-ads-conversion="whatsapp-implantologia"
              >Scrivi su WhatsApp</a>
            </div>
            <ul class="implant-hero__assurances" aria-label="Informazioni sulla richiesta">
              <li>Questionario anamnestico guidato</li>
              <li>Richiesta senza conferma automatica</li>
              <li>Ricontatto da parte dello studio</li>
            </ul>
          </div>

          <div class="implant-hero__form">
            <ImplantologiaAnamnesiForm slug={page.slug} serviceInterest={page.serviceInterest} />
          </div>
        </div>
      </section>

      <section class="implant-section implant-problem" id="problema" aria-labelledby="problema-title">
        <div class="implant-container implant-editorial-grid">
          <div class="implant-editorial-grid__heading">
            <p class="implant-kicker">Il problema che vuoi risolvere</p>
            <h2 id="problema-title">Il problema non è solo estetico</h2>
            <p>{page.problemIntro}</p>
          </div>
          <div class="implant-problem__cards">
            {page.problemCards.map((card, index) => (
              <article class:list={[index === 0 && "implant-problem-card--featured"]}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="implant-section implant-section--paper" id="cosa-puo-indicare" aria-labelledby="cause-title">
        <div class="implant-container">
          <div class="implant-heading implant-heading--centered">
            <p class="implant-kicker">Perché succede</p>
            <h2 id="cause-title">Cosa può indicare questa situazione</h2>
            <p>{page.causeIntro}</p>
          </div>
          <div class="implant-info-grid">
            {page.causeCards.map((card) => (
              <article>
                <span class="implant-info-grid__mark" aria-hidden="true"></span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="implant-section implant-method" id="metodo" aria-labelledby="method-title">
        <div class="implant-container implant-method__grid">
          <div class="implant-method__copy">
            <p class="implant-kicker implant-kicker--light">Come possiamo aiutarti</p>
            <h2 id="method-title">Non partiamo dall’impianto. Partiamo dal tuo caso.</h2>
            <p>
              Una soluzione implantologica non è uguale per tutti. Prima ascoltiamo il problema, valutiamo la
              situazione clinica e poi spieghiamo le opzioni realmente percorribili.
            </p>
            <strong>L’obiettivo è trasformare un problema incerto in un percorso chiaro.</strong>
          </div>
          <div class="implant-method__cards">
            {methodCards.map((card) => (
              <article>
                <span>{card.number}</span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="implant-section implant-process" id="percorso" aria-labelledby="process-title">
        <div class="implant-container">
          <div class="implant-heading implant-heading--centered">
            <p class="implant-kicker">Tre passaggi, una direzione chiara</p>
            <h2 id="process-title">Come ti accompagniamo verso una soluzione</h2>
            <p>Un percorso comprensibile riduce l’incertezza e ti permette di decidere con più consapevolezza.</p>
          </div>
          <div class="implant-process__card">
            {processSteps.map((step) => (
              <article>
                <span>{step.number}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <ImplantologiaReviews />

      <section class="implant-section implant-section--compact" aria-labelledby="mid-cta-title">
        <div class="implant-container">
          <div class="implant-cta-panel implant-cta-panel--horizontal">
            <div>
              <p class="implant-kicker implant-kicker--light">Il primo passo</p>
              <h2 id="mid-cta-title">Vuoi capire da dove partire?</h2>
              <p>Compila il questionario: bastano pochi passaggi per inviare la richiesta allo studio.</p>
            </div>
            <div class="implant-actions">
              <a class="implant-button implant-button--accent" href="#prenota">Inizia dal modulo</a>
              <a
                class="implant-button implant-button--ghost"
                href="https://wa.me/393892490181"
                target="_blank"
                rel="noopener noreferrer"
                data-google-ads-conversion="whatsapp-implantologia"
              >Scrivi su WhatsApp</a>
            </div>
          </div>
        </div>
      </section>

      <section class="implant-section implant-section--paper" id="visita" aria-labelledby="visit-title">
        <div class="implant-container implant-visit-grid">
          <div class="implant-visit-grid__copy">
            <p class="implant-kicker">Meno dubbi prima di decidere</p>
            <h2 id="visit-title">Cosa valuteremo durante la visita</h2>
            <p>
              La visita serve a costruire un quadro clinico, capire le opzioni davvero pertinenti e spiegarti cosa
              richiede ciascun percorso.
            </p>
            <p class="implant-clinical-note">
              Gli eventuali esami e il piano vengono definiti dal professionista in base al caso.
            </p>
          </div>
          <ul class="implant-visit-grid__checks">
            {visitChecks.map((item, index) => (
              <li><span>{String(index + 1).padStart(2, "0")}</span>{item}</li>
            ))}
          </ul>
        </div>
      </section>

      <section class="implant-section" id="altri-percorsi" aria-labelledby="related-title">
        <div class="implant-container">
          <div class="implant-heading">
            <p class="implant-kicker">Confronta le possibilità</p>
            <h2 id="related-title">Altri percorsi di implantologia</h2>
            <p>Ogni pagina parte da un’esigenza diversa. Scegli quella più vicina alla tua situazione.</p>
          </div>
          <div class="implant-related-grid">
            <a class="implant-related-card implant-related-card--hub" href="/implantologia/">
              <span>Inizia da qui</span>
              <strong>Percorso implantologico</strong>
              <small>Scopri il percorso implantologico dello studio.</small>
              <b aria-hidden="true">→</b>
            </a>
            {implantologiaPages.map((related) => (
              related.slug === page.slug ? (
                <article class="implant-related-card is-current" aria-current="page">
                  <span>Percorso attuale</span>
                  <strong>{related.cardTitle}</strong>
                  <small>{related.metaDescription}</small>
                  <b aria-hidden="true">Qui</b>
                </article>
              ) : (
                <a class="implant-related-card" href={`/implantologia/${related.slug}/`}>
                  <span>Soluzione</span>
                  <strong>{related.cardTitle}</strong>
                  <small>{related.metaDescription}</small>
                  <b aria-hidden="true">→</b>
                </a>
              )
            ))}
          </div>
        </div>
      </section>

      <section class="implant-section implant-section--paper" id="faq" aria-labelledby="faq-title">
        <div class="implant-container implant-faq-layout">
          <div class="implant-faq-layout__heading">
            <p class="implant-kicker">Domande frequenti</p>
            <h2 id="faq-title">Le risposte utili prima della valutazione</h2>
            <p>Informazioni chiare per capire cosa puoi aspettarti dal primo contatto e dalla visita.</p>
          </div>
          <div class="implant-faqs">
            {page.faqs.map((faq, index) => (
              <details open={index === 0}>
                <summary>{faq.question}<span aria-hidden="true">+</span></summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="implant-section implant-final-cta" aria-labelledby="final-cta-title">
        <div class="implant-container">
          <div class="implant-cta-panel implant-cta-panel--final">
            <div>
              <p class="implant-kicker implant-kicker--light">Sorriso &amp; Salute · Monza</p>
              <h2 id="final-cta-title">Il primo passo è capire quali opzioni hai davvero.</h2>
              <p>
                Invia la richiesta allo studio. La valutazione clinica servirà a definire indicazioni, alternative e
                passaggi del tuo caso.
              </p>
            </div>
            <div class="implant-actions">
              <a class="implant-button implant-button--accent" href="#prenota">Inizia la valutazione</a>
              <a
                class="implant-button implant-button--ghost"
                href="https://wa.me/393892490181"
                target="_blank"
                rel="noopener noreferrer"
                data-google-ads-conversion="whatsapp-implantologia"
              >Scrivi su WhatsApp</a>
            </div>
            <small>La richiesta online non conferma automaticamente l’appuntamento.</small>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter trackWhatsappAsImplantologia />

    <style is:global>
      :root {
        --implant-ink: #0e384c;
        --implant-ink-dark: #082a38;
        --implant-teal: #147d83;
        --implant-teal-deep: #0d676d;
        --implant-mint: #dff4f0;
        --implant-paper: #f5f9f8;
        --implant-line: #d6e2e2;
        --implant-body: #375765;
      }

      html { scroll-behavior: smooth; }

      body.implant-landing {
        margin: 0;
        overflow-x: hidden;
        background: #fff;
        color: var(--implant-body);
        font-family: "Plus Jakarta Sans", Inter, system-ui, sans-serif;
      }

      body.implant-landing *,
      body.implant-landing *::before,
      body.implant-landing *::after { box-sizing: border-box; }

      body.implant-landing a { color: inherit; }
      body.implant-landing main { overflow: clip; }
      .implant-container { width: min(1216px, calc(100% - 48px)); margin-inline: auto; }

      .implant-kicker {
        margin: 0 0 14px;
        color: var(--implant-teal);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .16em;
        line-height: 1.4;
        text-transform: uppercase;
      }

      .implant-kicker--light { color: #9ce2d7; }

      .implant-hero {
        position: relative;
        padding: clamp(74px, 7vw, 112px) 0 clamp(78px, 7vw, 112px);
        overflow: hidden;
        background:
          radial-gradient(circle at 86% 16%, rgba(47, 151, 148, .18), transparent 28%),
          radial-gradient(circle at 6% 88%, rgba(152, 219, 207, .25), transparent 25%),
          linear-gradient(135deg, #f1f9f7 0%, #fff 55%, #eef5f5 100%);
      }

      .implant-hero::before {
        position: absolute;
        top: 8%;
        right: -120px;
        width: 360px;
        height: 360px;
        border: 1px solid rgba(20, 125, 131, .13);
        border-radius: 50%;
        content: "";
      }

      .implant-hero__grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, .92fr) minmax(500px, 1.08fr);
        align-items: start;
        gap: clamp(44px, 6vw, 82px);
      }

      .implant-hero__copy { padding-top: clamp(18px, 4vw, 54px); }

      .implant-hero h1 {
        max-width: 10.8ch;
        margin: 0;
        color: var(--implant-ink);
        font-size: clamp(52px, 5.35vw, 78px);
        font-weight: 800;
        line-height: .99;
        letter-spacing: -.055em;
        text-wrap: balance;
      }

      .implant-hero h1 span { display: block; }
      .implant-hero h1 span:last-child { margin-top: 10px; color: var(--implant-teal); }

      .implant-hero__lead {
        max-width: 610px;
        margin: 28px 0 0;
        color: var(--color-text-description);
        font-size: clamp(18px, 1.55vw, 21px);
        line-height: 1.6;
      }

      .implant-clinical-note {
        max-width: 620px;
        margin: 16px 0 0;
        color: var(--color-text-description);
        font-size: 13px;
        line-height: 1.65;
      }

      .implant-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }

      .implant-button {
        display: inline-flex;
        min-height: 54px;
        align-items: center;
        justify-content: center;
        padding: 0 23px;
        border: 1px solid transparent;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 800;
        text-align: center;
        text-decoration: none;
        transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
      }

      .implant-button:hover { transform: translateY(-2px); }
      .implant-button:focus-visible { outline: 3px solid rgba(20, 125, 131, .3); outline-offset: 3px; }
      .implant-button--primary { background: var(--implant-ink); color: #fff !important; box-shadow: 0 12px 28px rgba(8, 42, 56, .18); }
      .implant-button--whatsapp { border-color: #76bca3; background: #fff; color: #0d6f4b !important; }
      .implant-button--accent { background: #9ce2d7; color: var(--implant-ink-dark) !important; }
      .implant-button--ghost { border-color: rgba(255, 255, 255, .3); background: rgba(255, 255, 255, .08); color: #fff !important; }

      .implant-hero__assurances {
        display: flex;
        flex-wrap: wrap;
        gap: 9px 18px;
        margin: 24px 0 0;
        padding: 0;
        color: var(--color-text-description);
        font-size: 12px;
        font-weight: 700;
        line-height: 1.5;
        list-style: none;
      }

      .implant-hero__assurances li { position: relative; padding-left: 18px; }
      .implant-hero__assurances li::before { position: absolute; left: 0; color: var(--implant-teal); content: "✓"; font-weight: 900; }
      .implant-hero__form { min-width: 0; }

      .implant-section { padding: clamp(80px, 8vw, 124px) 0; }
      .implant-section--paper { background: var(--implant-paper); }
      .implant-section--compact { padding: clamp(62px, 6vw, 88px) 0; }

      .implant-section h2,
      .implant-cta-panel h2 {
        margin: 0;
        color: var(--implant-ink);
        font-size: clamp(36px, 4.25vw, 58px);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -.045em;
        text-wrap: balance;
      }

      .implant-section p { line-height: 1.72; }
      .implant-heading { max-width: 760px; margin-bottom: 44px; }
      .implant-heading > p:last-child { max-width: 680px; margin: 20px 0 0; color: var(--color-text-description); font-size: 17px; }
      .implant-heading--centered { margin-right: auto; margin-left: auto; text-align: center; }
      .implant-heading--centered > p:last-child { margin-right: auto; margin-left: auto; }

      .implant-editorial-grid {
        display: grid;
        grid-template-columns: minmax(280px, .72fr) minmax(0, 1.28fr);
        align-items: start;
        gap: clamp(44px, 7vw, 96px);
      }

      .implant-editorial-grid__heading { position: sticky; top: calc(var(--implant-home-header-height) + 34px); }
      .implant-editorial-grid__heading > p:last-child { margin: 22px 0 0; color: var(--color-text-description); font-size: 17px; }

      .implant-problem__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .implant-problem__cards article {
        min-height: 230px;
        padding: 28px;
        border: 1px solid var(--implant-line);
        border-radius: 26px;
        background: #fff;
        box-shadow: 0 16px 44px rgba(8, 42, 56, .07);
      }

      .implant-problem__cards article:first-child { grid-column: 1 / -1; min-height: 205px; background: var(--implant-ink); color: var(--color-text-description-inverse); }
      .implant-problem__cards article > span { color: var(--implant-teal); font-size: 12px; font-weight: 900; letter-spacing: .12em; }
      .implant-problem__cards article:first-child > span { color: #9ce2d7; }
      .implant-problem__cards h3 { margin: 48px 0 10px; color: var(--implant-ink); font-size: clamp(20px, 2vw, 26px); line-height: 1.22; }
      .implant-problem__cards article:first-child h3 { margin-top: 38px; color: #fff; }
      .implant-problem__cards p { margin: 0; color: var(--color-text-description); font-size: 14px; }
      .implant-problem__cards article:first-child p { max-width: 620px; color: var(--color-text-description-inverse); }

      .implant-info-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
      .implant-info-grid article {
        min-height: 285px;
        padding: 30px;
        border: 1px solid rgba(14, 56, 76, .09);
        border-radius: 28px;
        background: #fff;
      }

      .implant-info-grid__mark { display: block; width: 54px; height: 8px; border-radius: 999px; background: var(--implant-teal); }
      .implant-info-grid h3 { margin: 52px 0 12px; color: var(--implant-ink); font-size: 23px; line-height: 1.25; }
      .implant-info-grid p { margin: 0; color: var(--color-text-description); font-size: 14px; }

      .implant-method { position: relative; overflow: hidden; background: var(--implant-ink-dark); color: var(--color-text-description-inverse); }
      .implant-method::before {
        position: absolute;
        top: -300px;
        right: -240px;
        width: 620px;
        height: 620px;
        border: 1px solid rgba(156, 226, 215, .14);
        border-radius: 50%;
        content: "";
      }

      .implant-method__grid { position: relative; display: grid; grid-template-columns: minmax(0, .82fr) minmax(0, 1.18fr); align-items: center; gap: clamp(50px, 7vw, 98px); }
      .implant-method h2 { color: #fff; }
      .implant-method__copy > p:not(.implant-kicker) { margin: 24px 0 0; font-size: 17px; }
      .implant-method__copy > strong { display: block; max-width: 540px; margin-top: 28px; color: #9ce2d7; font-size: 20px; line-height: 1.5; }
      .implant-method__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .implant-method__cards article { min-height: 235px; padding: 26px; border: 1px solid rgba(255, 255, 255, .12); border-radius: 24px; background: rgba(255, 255, 255, .07); }
      .implant-method__cards span { color: #9ce2d7; font-size: 11px; font-weight: 900; letter-spacing: .12em; }
      .implant-method__cards h3 { margin: 48px 0 10px; color: #fff; font-size: 20px; line-height: 1.3; }
      .implant-method__cards p { margin: 0; font-size: 13px; }

      .implant-process__card {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        padding: clamp(20px, 3.5vw, 44px);
        border: 1px solid var(--implant-line);
        border-radius: 36px;
        background: #fff;
        box-shadow: 0 24px 64px rgba(8, 42, 56, .08);
      }

      .implant-process__card article { position: relative; padding: 20px 30px; }
      .implant-process__card article + article { border-left: 1px solid var(--implant-line); }
      .implant-process__card article > span { display: block; color: var(--implant-mint); font-size: clamp(64px, 7vw, 96px); font-weight: 800; line-height: .8; letter-spacing: -.08em; }
      .implant-process__card h3 { margin: 32px 0 12px; color: var(--implant-ink); font-size: 22px; }
      .implant-process__card p { margin: 0; color: var(--color-text-description); font-size: 14px; }

      .implant-cta-panel {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        background: var(--implant-ink-dark);
        color: var(--color-text-description-inverse);
        box-shadow: 0 26px 70px rgba(8, 42, 56, .18);
      }

      .implant-cta-panel::after {
        position: absolute;
        right: -90px;
        bottom: -150px;
        width: 330px;
        height: 330px;
        border: 42px solid rgba(156, 226, 215, .07);
        border-radius: 50%;
        content: "";
      }

      .implant-cta-panel h2 { color: #fff; }
      .implant-cta-panel p:not(.implant-kicker) { max-width: 680px; margin: 18px 0 0; }
      .implant-cta-panel--horizontal { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 44px; padding: clamp(34px, 5vw, 62px); }
      .implant-cta-panel--horizontal .implant-actions { position: relative; z-index: 1; justify-content: flex-end; margin-top: 0; }

      .implant-visit-grid { display: grid; grid-template-columns: minmax(0, .8fr) minmax(0, 1.2fr); align-items: start; gap: clamp(48px, 8vw, 110px); }
      .implant-visit-grid__copy > p:not(.implant-kicker):not(.implant-clinical-note) { margin: 22px 0 0; color: var(--color-text-description); font-size: 17px; }
      .implant-visit-grid__checks { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 0; padding: 0; list-style: none; }
      .implant-visit-grid__checks li { display: flex; min-height: 92px; align-items: center; gap: 15px; padding: 18px; border: 1px solid var(--implant-line); border-radius: 20px; background: #fff; color: var(--color-text-description); font-size: 14px; font-weight: 750; line-height: 1.4; }
      .implant-visit-grid__checks span { display: inline-flex; width: 34px; height: 34px; flex: 0 0 auto; align-items: center; justify-content: center; border-radius: 50%; background: var(--implant-mint); color: var(--implant-teal-deep); font-size: 10px; font-weight: 900; }

      .implant-related-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 14px; }
      .implant-related-card { position: relative; display: flex; min-height: 255px; flex-direction: column; padding: 24px; border: 1px solid var(--implant-line); border-radius: 24px; background: #fff; color: var(--implant-ink); text-decoration: none; transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease; }
      a.implant-related-card:hover { transform: translateY(-4px); border-color: rgba(20, 125, 131, .45); box-shadow: 0 18px 40px rgba(8, 42, 56, .09); }
      .implant-related-card--hub { background: var(--implant-ink); color: #fff !important; }
      .implant-related-card.is-current { border: 2px solid var(--implant-teal); background: #edf8f6; }
      .implant-related-card > span { color: var(--implant-teal); font-size: 10px; font-weight: 850; letter-spacing: .13em; text-transform: uppercase; }
      .implant-related-card--hub > span { color: #9ce2d7; }
      .implant-related-card strong { margin-top: 24px; font-size: 19px; line-height: 1.3; }
      .implant-related-card small { margin-top: 12px; color: var(--color-text-description); font-size: 11px; line-height: 1.55; }
      .implant-related-card--hub small { color: var(--color-text-description-inverse); }
      .implant-related-card b { margin-top: auto; padding-top: 22px; color: var(--implant-teal); font-size: 16px; }
      .implant-related-card--hub b { color: #9ce2d7; }

      .implant-faq-layout { display: grid; grid-template-columns: minmax(280px, .74fr) minmax(0, 1.26fr); align-items: start; gap: clamp(46px, 8vw, 110px); }
      .implant-faq-layout__heading { position: sticky; top: calc(var(--implant-home-header-height) + 34px); }
      .implant-faq-layout__heading > p:last-child { margin: 22px 0 0; color: var(--color-text-description); font-size: 16px; }
      .implant-faqs { display: grid; gap: 12px; }
      .implant-faqs details { border: 1px solid var(--implant-line); border-radius: 20px; background: #fff; padding: 0 22px; }
      .implant-faqs details[open] { box-shadow: 0 12px 34px rgba(8, 42, 56, .06); }
      .implant-faqs summary { display: flex; min-height: 74px; align-items: center; justify-content: space-between; gap: 24px; color: var(--implant-ink); font-size: 15px; font-weight: 800; line-height: 1.45; cursor: pointer; list-style: none; }
      .implant-faqs summary::-webkit-details-marker { display: none; }
      .implant-faqs summary span { display: inline-flex; width: 30px; height: 30px; flex: 0 0 auto; align-items: center; justify-content: center; border-radius: 50%; background: var(--implant-mint); color: var(--implant-teal-deep); font-size: 18px; transition: transform 180ms ease; }
      .implant-faqs details[open] summary span { transform: rotate(45deg); }
      .implant-faqs details p { margin: -3px 48px 22px 0; color: var(--color-text-description); font-size: 14px; }

      .implant-final-cta { padding-top: clamp(74px, 7vw, 108px); }
      .implant-cta-panel--final { padding: clamp(38px, 7vw, 84px); text-align: center; }
      .implant-cta-panel--final > div:first-child { position: relative; z-index: 1; max-width: 850px; margin-inline: auto; }
      .implant-cta-panel--final .implant-actions { position: relative; z-index: 1; justify-content: center; }
      .implant-cta-panel--final small { position: relative; z-index: 1; display: block; margin-top: 20px; color: var(--color-text-description-inverse); font-size: 11px; }

      @media (min-width: 1024px) {
        .implant-hero { padding-top: calc(var(--implant-home-header-height) + 54px); }

        body.implant-landing .implant-home-header.is-over-hero {
          color: var(--implant-ink);
          text-shadow: none;
        }

        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__logo-mark { background: var(--implant-ink); }
        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__nav { text-shadow: none; }
        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__nav-link:hover,
        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__nav-link:focus-visible,
        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__menu-toggle:hover,
        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__menu-toggle:focus-visible { color: var(--implant-teal-deep); opacity: 1; }
      }

      @media (min-width: 1024px) and (max-width: 1100px) {
        body.implant-landing .implant-home-header.is-over-hero .implant-home-header__menu-toggle {
          border-color: rgba(14, 56, 76, .22);
          background: rgba(255, 255, 255, .72);
          color: var(--implant-ink);
        }
      }

      @media (max-width: 1100px) {
        .implant-hero__grid { grid-template-columns: minmax(0, .85fr) minmax(460px, 1.15fr); gap: 36px; }
        .implant-related-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      }

      @media (max-width: 900px) {
        .implant-hero__grid,
        .implant-editorial-grid,
        .implant-method__grid,
        .implant-visit-grid,
        .implant-faq-layout { grid-template-columns: 1fr; }

        .implant-hero__copy { padding-top: 0; }
        .implant-hero h1 { max-width: 12ch; }
        .implant-hero__form { width: min(100%, 680px); }
        .implant-editorial-grid__heading,
        .implant-faq-layout__heading { position: static; }
        .implant-info-grid { grid-template-columns: 1fr 1fr; }
        .implant-process__card { grid-template-columns: 1fr; }
        .implant-process__card article { display: grid; grid-template-columns: 94px 1fr; align-items: start; gap: 16px; }
        .implant-process__card article + article { border-top: 1px solid var(--implant-line); border-left: 0; }
        .implant-process__card h3 { margin-top: 0; }
        .implant-cta-panel--horizontal { grid-template-columns: 1fr; }
        .implant-cta-panel--horizontal .implant-actions { justify-content: flex-start; }
      }

      @media (max-width: 620px) {
        .implant-container { width: min(100% - 28px, 1216px); }
        .implant-hero { padding-top: 24px; padding-bottom: 54px; }
        .implant-hero__grid { gap: 22px; }
        .implant-hero h1 {
          max-width: none;
          font-size: clamp(34px, 10.25vw, 42px);
          line-height: .98;
          letter-spacing: -.045em;
        }
        .implant-hero h1 span:last-child { margin-top: 5px; }
        .implant-hero__lead { margin-top: 14px; font-size: 15px; line-height: 1.45; }
        .implant-hero .implant-clinical-note { margin-top: 8px; font-size: 11px; line-height: 1.45; }
        .implant-hero .implant-actions {
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          width: 100%;
          gap: 8px;
          margin-top: 14px;
        }
        .implant-hero .implant-button { width: 100%; min-height: 46px; padding: 7px 12px; font-size: 12px; }
        .implant-hero__assurances {
          display: flex;
          gap: 5px 12px;
          margin-top: 12px;
          font-size: 10px;
          line-height: 1.35;
        }
        .implant-hero__assurances li { padding-left: 14px; }
        .implant-actions { width: 100%; }
        .implant-button { width: 100%; }
        .implant-section { padding: 72px 0; }
        .implant-section--compact { padding: 52px 0; }
        .implant-section h2,
        .implant-cta-panel h2 { font-size: clamp(33px, 10vw, 45px); }
        .implant-problem__cards,
        .implant-info-grid,
        .implant-method__cards,
        .implant-visit-grid__checks,
        .implant-related-grid { grid-template-columns: 1fr; }
        .implant-problem__cards article:first-child { grid-column: auto; }
        .implant-info-grid article,
        .implant-problem__cards article,
        .implant-problem__cards article:first-child,
        .implant-method__cards article { min-height: 0; }
        .implant-problem__cards h3,
        .implant-problem__cards article:first-child h3,
        .implant-info-grid h3,
        .implant-method__cards h3 { margin-top: 30px; }
        .implant-process__card { padding: 12px; border-radius: 26px; }
        .implant-process__card article { grid-template-columns: 64px 1fr; padding: 24px 14px; }
        .implant-process__card article > span { font-size: 58px; }
        .implant-cta-panel { border-radius: 28px; }
        .implant-cta-panel--horizontal,
        .implant-cta-panel--final { padding: 30px 22px; }
        .implant-related-card { min-height: 220px; }
        .implant-faqs details { padding: 0 17px; }
        .implant-faqs details p { margin-right: 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .implant-button,
        .implant-related-card,
        .implant-faqs summary span { transition: none; }
      }
    </style>
  </body>
</html>
