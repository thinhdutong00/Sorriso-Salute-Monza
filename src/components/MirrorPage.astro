const mirrorHeaderScript = `
(() => {
  const body = document.body;
  const header = document.querySelector(".ekit-template-content-header");
  if (!header) return;

  let lastY = window.scrollY;
  let ticking = false;

  const getHero = () => {
    if (body.classList.contains("home")) {
      return document.querySelector(".elementor-7051 .elementor-element.elementor-element-5c1edef1");
    }

    return (
      document.querySelector('.elementor[data-elementor-type="wp-page"] > .elementor-element:first-child:has(.elementor-widget-elementskit-breadcrumb)') ||
      document.querySelector(".elementor-widget-elementskit-breadcrumb")?.closest(".elementor-element") ||
      document.querySelector('.elementor[data-elementor-type="wp-page"] > .elementor-element:first-child')
    );
  };

  const updateHeader = () => {
    const currentY = Math.max(0, window.scrollY || window.pageYOffset || 0);
    const hero = getHero();
    const headerHeight = header.getBoundingClientRect().height || 88;
    const heroBottom = hero ? hero.getBoundingClientRect().bottom + currentY : window.innerHeight * 0.72;
    const isPastHero = currentY + headerHeight >= heroBottom - 8;
    const scrollingDown = currentY > lastY + 6;
    const scrollingUp = currentY < lastY - 6;

    body.classList.toggle("mirror-header-over-hero", !isPastHero);
    body.classList.toggle("mirror-header-solid", isPastHero);

    if (currentY <= 12 || scrollingUp) {
      body.classList.remove("mirror-header-hidden");
    } else if (scrollingDown && currentY > headerHeight + 28) {
      body.classList.add("mirror-header-hidden");
    }

    lastY = currentY;
    ticking = false;
  };

  const requestUpdate = () => {
    if (ticking) return;
    ticking = true;
    window.requestAnimationFrame(updateHeader);
  };

  updateHeader();
  window.addEventListener("scroll", requestUpdate, { passive: true });
  window.addEventListener("resize", requestUpdate);
  window.addEventListener("load", updateHeader);
})();
`;

const mirrorNavigationScript = `
(() => {
  const body = document.body;
  const panel = document.querySelector("[data-mirror-kebab-menu]");
  const backdrop = document.querySelector("[data-mirror-menu-backdrop]");
  const closeButton = document.querySelector("[data-mirror-menu-close]");

  const normalise = (value) =>
    (value || "")
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\\u0300-\\u036f]/g, "")
      .trim();

  const getNav = () => document.querySelector(".ekit-template-content-header .elementskit-navbar-nav");

  const phoneIcon =
    '<svg class="mirror-nav-link__icon" aria-hidden="true" viewBox="0 0 24 24" focusable="false"><path d="M6.62 10.79c1.44 2.83 3.76 5.15 6.59 6.59l2.2-2.2c.31-.31.76-.42 1.17-.28 1.29.43 2.64.66 4.02.66.66 0 1.2.54 1.2 1.2v3.48c0 .66-.54 1.2-1.2 1.2C10.43 21.94 2.06 13.57 2.06 3.4c0-.66.54-1.2 1.2-1.2h3.49c.66 0 1.2.54 1.2 1.2 0 1.38.22 2.73.66 4.02.13.41.03.86-.29 1.17l-2.2 2.2Z" fill="currentColor"/></svg>';

  const createNavLink = (className, href, label, trailingIcon = "") => {
    const item = document.createElement("li");
    item.className = "menu-item nav-item elementskit-mobile-builder-content " + className;
    const link = document.createElement("a");
    link.className = "ekit-menu-nav-link mirror-nav-link";
    link.href = href;
    link.innerHTML = "<span>" + label + "</span>" + trailingIcon;
    item.append(link);
    return item;
  };

  const createMenuButton = () => {
    const item = document.createElement("li");
    item.className = "menu-item nav-item elementskit-mobile-builder-content mirror-nav-menu-item";
    const button = document.createElement("button");
    button.className = "ekit-menu-nav-link mirror-menu-toggle";
    button.type = "button";
    button.setAttribute("data-mirror-menu-toggle", "");
    button.setAttribute("aria-controls", "mirror-kebab-menu");
    button.setAttribute("aria-expanded", "false");
    button.innerHTML =
      '<span class="mirror-menu-toggle__icon" aria-hidden="true"><span></span><span></span><span></span></span><span>Menu</span>';
    item.append(button);
    return item;
  };

  const enhanceNav = () => {
    const nav = getNav();
    if (!nav) {
      window.setTimeout(enhanceNav, 120);
      return;
    }

    Array.from(nav.children).forEach((item) => {
      if (!(item instanceof HTMLElement) || item.tagName !== "LI") return;
      if (item.classList.contains("mirror-nav-item")) return;
      const link = item.querySelector("a");
      const label = normalise(link?.textContent);
      const href = link?.getAttribute("href") || "";
      if (
        label === "home" ||
        label === "chi siamo" ||
        label.startsWith("chi siamo") ||
        label === "attivita" ||
        label.startsWith("attivita") ||
        label === "la struttura" ||
        label === "contatti" ||
        href === "/" ||
        href.includes("/chi-siamo") ||
        href.includes("/attivita/") ||
        href.includes("/struttura-studio-dentistico-monza") ||
        href.includes("/contatti")
      ) {
        item.classList.add("mirror-nav-item-hidden");
      }
    });

    if (!nav.querySelector(".mirror-nav-reviews")) {
      const reviews = createNavLink("mirror-nav-item mirror-nav-reviews", "/recensioni-studio-dentistico-monza/", "Dicono di noi");
      const structure = createNavLink("mirror-nav-item mirror-nav-structure", "/struttura-studio-dentistico-monza/", "La Struttura");
      const conventions = createNavLink("mirror-nav-item mirror-nav-conventions", "/convenzioni-dirette-studio-dentistico-monza/", "Convenzioni");
      const urgent = createNavLink("mirror-nav-item mirror-nav-urgent", "/urgenze/", "Urgenze");
      const call = createNavLink("mirror-nav-item mirror-nav-call", "tel:+390392022489", "Chiama in studio", phoneIcon);
      const menu = createMenuButton();
      nav.append(reviews, structure, conventions, urgent, call, menu);
    }
  };

  const setMenuState = (isOpen) => {
    if (!panel || !backdrop) return;
    panel.hidden = !isOpen;
    backdrop.hidden = !isOpen;
    body.classList.toggle("mirror-menu-open", isOpen);
    document.querySelectorAll("[data-mirror-menu-toggle]").forEach((button) => {
      button.setAttribute("aria-expanded", String(isOpen));
    });
    if (isOpen) panel.focus({ preventScroll: true });
  };

  enhanceNav();
  window.setTimeout(enhanceNav, 250);
  window.setTimeout(enhanceNav, 900);

  const observeNav = () => {
    const nav = getNav();
    if (!nav || nav.dataset.mirrorNavObserved) return;
    nav.dataset.mirrorNavObserved = "true";
    new MutationObserver(() => window.requestAnimationFrame(enhanceNav)).observe(nav, {
      childList: true,
      subtree: true,
    });
  };

  observeNav();
  window.setTimeout(observeNav, 300);

  document.addEventListener("click", (event) => {
    const toggle = event.target.closest("[data-mirror-menu-toggle]");
    if (toggle) {
      event.preventDefault();
      setMenuState(panel?.hidden !== false);
      return;
    }

    if (event.target.closest("[data-mirror-menu-close]") || event.target === backdrop) {
      event.preventDefault();
      setMenuState(false);
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenuState(false);
  });

  closeButton?.addEventListener("click", () => setMenuState(false));
})();
`;

const counterFallbackScript = `
(() => {
  const formatCounterValue = (value, delimiter) => {
    const roundedValue = Math.round(value);

    if (!delimiter) {
      return String(roundedValue);
    }

    return new Intl.NumberFormat("en-US")
      .format(roundedValue)
      .replaceAll(",", delimiter);
  };

  const animateCounter = (counter) => {
    if (counter.dataset.counterFallbackDone === "true") return;

    const targetValue = Number(counter.dataset.toValue || counter.dataset.value);
    const startValue = Number(counter.dataset.fromValue || 0);
    const duration = Number(counter.dataset.duration || counter.dataset.animationDuration || 1200);
    const delimiter = counter.dataset.delimiter || "";

    if (!Number.isFinite(targetValue)) return;

    counter.dataset.counterFallbackDone = "true";

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches || duration <= 0) {
      counter.textContent = formatCounterValue(targetValue, delimiter);
      return;
    }

    const startTime = window.performance.now();

    const step = (currentTime) => {
      const progress = Math.min((currentTime - startTime) / duration, 1);
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      const currentValue = startValue + (targetValue - startValue) * easedProgress;

      counter.textContent = formatCounterValue(currentValue, delimiter);

      if (progress < 1) {
        window.requestAnimationFrame(step);
      }
    };

    window.requestAnimationFrame(step);
  };

  const initCounters = () => {
    const counters = Array.from(document.querySelectorAll(".elementor-counter-number[data-to-value], .number-percentage[data-value]"));

    if (!counters.length) return;

    if (!("IntersectionObserver" in window)) {
      counters.forEach(animateCounter);
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          observer.unobserve(entry.target);
          animateCounter(entry.target);
        });
      },
      {
        rootMargin: "0px 0px -10% 0px",
        threshold: 0.15,
      },
    );

    counters.forEach((counter) => observer.observe(counter));
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCounters, { once: true });
  } else {
    initCounters();
  }
})();
`;

