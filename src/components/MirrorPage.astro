---
import { readFile } from "node:fs/promises";
import path from "node:path";
import BrandPalette from "./BrandPalette.astro";
import GoogleAdsTracking from "./GoogleAdsTracking.astro";
import PageLoader from "./PageLoader.astro";
import manifest from "../data/mirror/manifest.json";

interface Props {
  mirrorPath: string;
}

const { mirrorPath } = Astro.props;
const page = manifest.pages.find((entry) => entry.path === mirrorPath);

if (!page) {
  throw new Error(`Missing mirrored page for ${mirrorPath}`);
}

const pagesDir = path.resolve("src/data/mirror/pages");
const [rawHead, rawBody] = await Promise.all([
  readFile(path.join(pagesDir, page.headFile), "utf8"),
  readFile(path.join(pagesDir, page.bodyFile), "utf8"),
]);

const replaceFirst = (source: string, search: string, replacement: string) => source.replace(search, replacement);

const applyActivityIndexItalianHead = (html: string) => {
  if (page.path !== "/attivita/") return html;

  return html
    .replace(
      'content="Services Home Dental Care We are excited to meet you and provide the best dental [&hellip;]"',
      'content="Scopri le attività odontoiatriche dello Studio Dentistico Sorriso & Salute a Monza."',
    )
    .replaceAll('"inLanguage":"en-US"', '"inLanguage":"it-IT"')
    .replace('hreflang="en-US"', 'hreflang="it-IT"')
    .replace('hreflang="en"', 'hreflang="it"');
};

const applyActivityIndexItalianBody = (html: string) => {
  if (page.path !== "/attivita/") return html;

  const cards = [
    {
      oldTitle: "Dental Care",
      oldHref: "https://demo.awaikenthemes.com/primecare/demo2/services/dental-care/",
      title: "Igiene orale e profilassi",
      description: "Igiene professionale, prevenzione e controlli periodici per mantenere denti e gengive in salute.",
      href: "/attivita/igiene-orale-e-profilassi/",
    },
    {
      oldTitle: "Cosmetic Dentistry",
      oldHref: "https://demo.awaikenthemes.com/primecare/demo2/services/cosmetic-dentistry/",
      title: "Estetica del sorriso",
      description: "Trattamenti estetici per migliorare armonia, colore e naturalezza del sorriso.",
      href: "/attivita/estetica-del-sorriso/",
    },
    {
      oldTitle: "Dental Implants",
      oldHref: "https://demo.awaikenthemes.com/primecare/demo2/services/dental-implants/",
      title: "Implantologia",
      description: "Impianti dentali in titanio per tornare a sorridere e masticare con sicurezza.",
      href: "/implantologia/",
    },
    {
      oldTitle: "Teeth Whitening",
      oldHref: "https://demo.awaikenthemes.com/primecare/demo2/services/teeth-whitening/",
      title: "Odontoiatria conservativa",
      description: "Cura delle lesioni dei denti e restauri conservativi per preservare struttura e funzione.",
      href: "/attivita/odontoiatria-conservativa/",
    },
    {
      oldTitle: "Emergency Dental Care",
      title: "Chirurgia orale",
      description: "Estrazioni, rimozione di lesioni e interventi chirurgici gestiti con attenzione e pianificazione.",
      href: "/attivita/chirurgia-orale/",
    },
    {
      oldTitle: "Dental Sealants",
      title: "Parodontologia",
      description: "Diagnosi e trattamento dei problemi gengivali e dei tessuti di sostegno del dente.",
      href: "/attivita/parodontologia/",
    },
    {
      oldTitle: "Pediatric Dentistry",
      title: "Pedodonzia",
      description: "Cure odontoiatriche dedicate ai bambini, con approccio attento e rassicurante.",
      href: "/attivita/pedodonzia/",
    },
    {
      oldTitle: "Restorative Dentistry",
      title: "Protesi dentale",
      description: "Soluzioni protesiche fisse o mobili per ripristinare estetica e funzione masticatoria.",
      href: "/attivita/protesi-dentale/",
    },
  ];

  let next = html
    .replace(
      '<h1 class="elementor-heading-title elementor-size-default">Services</h1>',
      '<h1 class="elementor-heading-title elementor-size-default">Attività</h1>',
    )
    .replace("Personalized Care For Patient", "Cure personalizzate")
    .replace(
      "We understand that each patient is unique, and listen to concerns.",
      "Ascoltiamo ogni paziente e costruiamo percorsi di cura adatti alle sue esigenze.",
    )
    .replace("Family Friendly", "Studio accogliente")
    .replace(
      "No matter your age or dental needs, we are here to help.",
      "Accogliamo adulti e bambini con attenzione, chiarezza e continuità.",
    )
    .replace("Why Choose Us", "Perché scegliere Sorriso & Salute")
    .replace("Exceptional dental care tailored to your needs", "Cure odontoiatriche pensate per le tue esigenze")
    .replace(
      "We take the time to understand your individual needs and goals, creating customized treatment plans to help you achieve optimal oral health.",
      "Dedichiamo tempo all’ascolto delle esigenze di ogni paziente e costruiamo piani di cura personalizzati per raggiungere salute, funzione ed estetica.",
    )
    .replace(
      "we believe that your dental experience should be more than just a routine visit. Our goal is to provide comprehensive, personalized care in a welcoming environment, where your comfort and well-being come first.",
      "Crediamo che l’esperienza dal dentista debba essere chiara, serena e accompagnata passo dopo passo. Il nostro obiettivo è offrire cure complete in un ambiente accogliente, dove comfort e benessere vengono prima di tutto.",
    )
    .replace("Years Of Experience", "Anni di attività")
    .replace("Happy Patients", "Persone aiutate")
    .replace("Treatment Completed", "Impianti e protesi")
    .replace('data-to-value="20"', 'data-to-value="23"')
    .replace('data-to-value="5"', 'data-to-value="10"')
    .replace('data-to-value="986"', 'data-to-value="10"')
    .replace('<span class="elementor-counter-number-suffix">M+</span>', '<span class="elementor-counter-number-suffix">.000+</span>')
    .replace(
      /(<div class="elementor-counter-title">Impianti e protesi<\/div>[\s\S]*?<span class="elementor-counter-number-suffix">)\+/,
      "$1.000+",
    )
    .replace("Testimonials", "Recensioni")
    .replace("Listen from our happy patients", "Le parole dei nostri pazienti")
    .replace(
      "The goal of our clinic is to provide friendly, caring dentistry and the highest level of general, cosmetic, and specialist dental treatments. With dental practices throughout the world.",
      "Ogni percorso nasce dall’ascolto e da una diagnosi chiara, con l’obiettivo di offrire cure precise, comprensibili e adatte alla persona.",
    )
    .replaceAll(
      "I want to say thank you to my doctor Steve! Vivamus sagittis massa vitae bibendum rhoncus. Duis cursus.” “Thank you for helping me overcome my fear of the dentist! Vivamus sagittis massa vitae bibendum rhoncus. Duis cursus.",
      "Professionalità, attenzione e chiarezza in ogni fase del percorso. Mi sono sentito seguito e ascoltato fin dalla prima visita.",
    )
    .replaceAll("Patient", "Paziente")
    .replace("Dianne Russell", "Paziente Sorriso & Salute")
    .replace("Jane Cooper", "Paziente Sorriso & Salute")
    .replace("Artemisia Udinese", "Paziente Sorriso & Salute")
    .replace("jenny wilson", "Paziente Sorriso & Salute");

  for (const card of cards) {
    next = replaceFirst(next, card.oldTitle, card.title);
    next = replaceFirst(
      next,
      "<p>We are excited to meet you and provide the best dental care.</p>",
      `<p>${card.description}</p>`,
    );

    if (card.oldHref) {
      next = next.replace(card.oldHref, card.href);
    } else {
      next = replaceFirst(
        next,
        '<a class="elementskit-btn whitespace--normal" href="#">',
        `<a class="elementskit-btn whitespace--normal" href="${card.href}">`,
      );
    }
  }

  return next.replaceAll("Learn More", "Nel dettaglio");
};

const head = applyActivityIndexItalianHead(rawHead);
const body = applyActivityIndexItalianBody(rawBody).replaceAll(
  "Un sorriso più sano non può aspettare, <br />Prenota ora!",
  "Un sorriso<br />che sembri tuo,<br />solo migliore.",
);

const isActivityServicePage =
  page.path.startsWith("/attivita/") &&
  page.path !== "/attivita/" &&
  page.path !== "/attivita/implantologia/";

const serviceTitleMatch = body.match(/<h1[^>]*>([\s\S]*?)<\/h1>/i);
const serviceTitle = serviceTitleMatch
  ? serviceTitleMatch[1].replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim()
  : page.title.split("|")[0].trim();
const stickyCtaText = isActivityServicePage
  ? serviceTitle
  : "Richiedi una visita in meno di 2 minuti";
const stickyCtaButtonText = isActivityServicePage ? "Richiedi una visita" : "vai al modulo";
const stickyCtaLabel = isActivityServicePage ? "Servizio" : "";
const stickyCtaVariant = isActivityServicePage
  ? "activity-sticky-cta activity-sticky-cta--service"
  : "activity-sticky-cta activity-sticky-cta--generic";

const activityStickyScript = `
(() => {
  const bar = document.querySelector("[data-activity-sticky-cta]");
  if (!bar) return;

  const hero =
    document.querySelector('.elementor[data-elementor-type="wp-page"] > .elementor-element:first-child') ||
    document.querySelector(".elementor-widget-elementskit-breadcrumb")?.closest(".elementor-element");
  const footer = document.querySelector(".ekit-template-content-footer") || document.querySelector("footer");

  const updateVisibility = () => {
    const threshold = hero
      ? hero.getBoundingClientRect().bottom + window.scrollY - 24
      : Math.round(window.innerHeight * 0.72);
    const isPastHero = window.scrollY > threshold;
    const isAtFooterEnd = footer
      ? footer.getBoundingClientRect().bottom <= window.innerHeight + 2
      : false;

    bar.classList.toggle("is-visible", isPastHero && !isAtFooterEnd);
  };

  updateVisibility();
  window.addEventListener("scroll", updateVisibility, { passive: true });
  window.addEventListener("resize", updateVisibility);
})();
`;

const removeLegacyAppointmentButtonScript = `
document.querySelectorAll(".btn-scroll-centrato").forEach((button) => button.remove());
`;

const mirrorHeaderScript = `
(() => {
  const body = document.body;
  const header = document.querySelector(".ekit-template-content-header");
  if (!header) return;

  let lastY = window.scrollY;
  let ticking = false;

  const getHero = () => {
    if (body.classList.contains("home")) {
      return document.querySelector(".elementor-7051 .elementor-element.elementor-element-5c1edef1");
    }

    return (
      document.querySelector('.elementor[data-elementor-type="wp-page"] > .elementor-element:first-child:has(.elementor-widget-elementskit-breadcrumb)') ||
      document.querySelector(".elementor-widget-elementskit-breadcrumb")?.closest(".elementor-element") ||
      document.querySelector('.elementor[data-elementor-type="wp-page"] > .elementor-element:first-child')
    );
  };

  const updateHeader = () => {
    const currentY = Math.max(0, window.scrollY || window.pageYOffset || 0);
    const hero = getHero();
    const headerHeight = header.getBoundingClientRect().height || 88;
    const heroBottom = hero ? hero.getBoundingClientRect().bottom + currentY : window.innerHeight * 0.72;
    const isPastHero = currentY + headerHeight >= heroBottom - 8;
    const scrollingDown = currentY > lastY + 6;
    const scrollingUp = currentY < lastY - 6;

    body.classList.toggle("mirror-header-over-hero", !isPastHero);
    body.classList.toggle("mirror-header-solid", isPastHero);

    if (currentY <= 12 || scrollingUp) {
      body.classList.remove("mirror-header-hidden");
    } else if (scrollingDown && currentY > headerHeight + 28) {
      body.classList.add("mirror-header-hidden");
    }

    lastY = currentY;
    ticking = false;
  };

  const requestUpdate = () => {
    if (ticking) return;
    ticking = true;
    window.requestAnimationFrame(updateHeader);
  };

  updateHeader();
  window.addEventListener("scroll", requestUpdate, { passive: true });
  window.addEventListener("resize", requestUpdate);
  window.addEventListener("load", updateHeader);
})();
`;

const mirrorNavigationScript = `
(() => {
  const body = document.body;
  const panel = document.querySelector("[data-mirror-kebab-menu]");
  const backdrop = document.querySelector("[data-mirror-menu-backdrop]");
  const closeButton = document.querySelector("[data-mirror-menu-close]");

  const normalise = (value) =>
    (value || "")
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\\u0300-\\u036f]/g, "")
      .trim();

  const getNav = () => document.querySelector(".ekit-template-content-header .elementskit-navbar-nav");

  const createNavLink = (className, href, label) => {
    const item = document.createElement("li");
    item.className = "menu-item nav-item elementskit-mobile-builder-content " + className;
    const link = document.createElement("a");
    link.className = "ekit-menu-nav-link mirror-nav-link";
    link.href = href;
    link.textContent = label;
    item.append(link);
    return item;
  };

  const createMenuButton = () => {
    const item = document.createElement("li");
    item.className = "menu-item nav-item elementskit-mobile-builder-content mirror-nav-menu-item";
    const button = document.createElement("button");
    button.className = "ekit-menu-nav-link mirror-menu-toggle";
    button.type = "button";
    button.setAttribute("data-mirror-menu-toggle", "");
    button.setAttribute("aria-controls", "mirror-kebab-menu");
    button.setAttribute("aria-expanded", "false");
    button.innerHTML =
      '<span class="mirror-menu-toggle__icon" aria-hidden="true"><span></span><span></span><span></span></span><span>Menu</span>';
    item.append(button);
    return item;
  };

  const enhanceNav = () => {
    const nav = getNav();
    if (!nav) {
      window.setTimeout(enhanceNav, 120);
      return;
    }

    Array.from(nav.children).forEach((item) => {
      if (!(item instanceof HTMLElement) || item.tagName !== "LI") return;
      if (item.classList.contains("mirror-nav-item")) return;
      const link = item.querySelector("a");
      const label = normalise(link?.textContent);
      const href = link?.getAttribute("href") || "";
      if (
        label === "chi siamo" ||
        label.startsWith("chi siamo") ||
        label === "attivita" ||
        label.startsWith("attivita") ||
        href.includes("/chi-siamo") ||
        href.includes("/attivita/")
      ) {
        item.classList.add("mirror-nav-item-hidden");
      }
    });

    if (!nav.querySelector(".mirror-nav-urgent")) {
      const urgent = createNavLink("mirror-nav-item mirror-nav-urgent", "/urgenze/", "Urgenze");
      const call = createNavLink("mirror-nav-item mirror-nav-call", "tel:+390392022489", "Chiama in studio");
      const menu = createMenuButton();
      nav.append(urgent, call, menu);
    }
  };

  const setMenuState = (isOpen) => {
    if (!panel || !backdrop) return;
    panel.hidden = !isOpen;
    backdrop.hidden = !isOpen;
    body.classList.toggle("mirror-menu-open", isOpen);
    document.querySelectorAll("[data-mirror-menu-toggle]").forEach((button) => {
      button.setAttribute("aria-expanded", String(isOpen));
    });
    if (isOpen) panel.focus({ preventScroll: true });
  };

  enhanceNav();
  window.setTimeout(enhanceNav, 250);
  window.setTimeout(enhanceNav, 900);

  const observeNav = () => {
    const nav = getNav();
    if (!nav || nav.dataset.mirrorNavObserved) return;
    nav.dataset.mirrorNavObserved = "true";
    new MutationObserver(() => window.requestAnimationFrame(enhanceNav)).observe(nav, {
      childList: true,
      subtree: true,
    });
  };

  observeNav();
  window.setTimeout(observeNav, 300);

  document.addEventListener("click", (event) => {
    const toggle = event.target.closest("[data-mirror-menu-toggle]");
    if (toggle) {
      event.preventDefault();
      setMenuState(panel?.hidden !== false);
      return;
    }

    if (event.target.closest("[data-mirror-menu-close]") || event.target === backdrop) {
      event.preventDefault();
      setMenuState(false);
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenuState(false);
  });

  closeButton?.addEventListener("click", () => setMenuState(false));
})();
`;
---

<!doctype html>
<html lang="it-IT">
  <head>
    <Fragment set:html={head} />
    <GoogleAdsTracking />
    <BrandPalette />
  </head>
  <body class:list={[page.bodyClass, "brand-palette", "mirror-header-over-hero"]} id={page.bodyId || undefined}>
    <PageLoader />
    <Fragment set:html={body} />
    <div class="mirror-menu-backdrop" data-mirror-menu-backdrop hidden></div>
    <aside
      id="mirror-kebab-menu"
      class="mirror-kebab-menu"
      data-mirror-kebab-menu
      tabindex="-1"
      aria-label="Menu principale"
      hidden
    >
      <div class="mirror-kebab-menu__header">
        <button type="button" class="mirror-kebab-menu__close" data-mirror-menu-close aria-label="Chiudi menu">
          <span aria-hidden="true">×</span>
          Chiudi
        </button>
      </div>
      <nav class="mirror-kebab-menu__content" aria-label="Navigazione estesa">
        <section class="mirror-kebab-menu__section">
          <h2>Studio</h2>
          <a href="/chi-siamo/">Chi siamo</a>
          <a href="/struttura-studio-dentistico-monza/">La Struttura</a>
          <a href="/contatti/">Contatti</a>
          <a href="/convenzioni-dirette-studio-dentistico-monza/">Convenzioni</a>
        </section>
        <section class="mirror-kebab-menu__section">
          <h2>Attività</h2>
          <a href="/attivita/">Tutte le attività</a>
          <a href="/attivita/igiene-orale-e-profilassi/">Igiene orale e profilassi</a>
          <a href="/attivita/protesi-dentale/">Protesi dentale</a>
          <a href="/attivita/odontoiatria-conservativa/">Conservativa</a>
          <a href="/attivita/estetica-del-sorriso/">Estetica del sorriso</a>
          <a href="/attivita/parodontologia/">Parodontologia</a>
          <a href="/attivita/ortodonzia/">Ortodonzia</a>
          <a href="/attivita/chirurgia-orale/">Chirurgia orale</a>
          <a href="/attivita/pedodonzia/">Pedodonzia</a>
          <a href="/attivita/gnatologia/">Gnatologia</a>
          <a href="/implantologia/">Implantologia</a>
        </section>
        <section class="mirror-kebab-menu__section">
          <h2>Prenota e informazioni</h2>
          <a href="/urgenze/">Urgenze</a>
          <a href="tel:+390392022489">Chiama in studio</a>
          <a href="/richiesta/">Richiedi appuntamento</a>
          <a href="/convenzioni-dirette/">Convenzioni dirette</a>
          <a href="/convenzioni-indirette/">Convenzioni indirette</a>
        </section>
      </nav>
    </aside>
    <script is:inline set:html={removeLegacyAppointmentButtonScript} />
    <script is:inline set:html={mirrorHeaderScript} />
    <script is:inline set:html={mirrorNavigationScript} />
    {
      (
        <aside class={stickyCtaVariant} data-activity-sticky-cta aria-label="Prenotazione visita">
          <div class="activity-sticky-cta__inner">
            <div class="activity-sticky-cta__service">
              {stickyCtaLabel && <span>{stickyCtaLabel}</span>}
              <strong>{stickyCtaText}</strong>
            </div>
            <a class="activity-sticky-cta__button" href="/richiesta/">
              {stickyCtaButtonText}
            </a>
          </div>
        </aside>
      )
    }
    <script is:inline set:html={activityStickyScript} />
  </body>
</html>
