      icon: icons.periodontology,
    },
    {
      slug: "orthodontics",
      titles: ["Ortodonzia"],
      image: "/assets/generated/treatment-aligner.png",
      alt: "Allineatori e ortodonzia",
      icon: icons.orthodontics,
    },
    {
      slug: "surgery",
      titles: ["Chirurgia Orale", "Chirurgia orale", "Emergency Dental Care"],
      image: "/mirror-assets/a5ef4bcf4eac89cb.jpg",
      alt: "Preparazione per chirurgia orale",
      icon: icons.surgery,
    },
    {
      slug: "implantology",
      titles: ["Implantologia", "Dental Implants"],
      image: "/assets/generated/treatment-implant.png",
      alt: "Implantologia dentale",
      icon: icons.implant,
    },
    {
      slug: "endodontics",
      titles: ["Endodonzia"],
      image: "/mirror-assets/8813161e3f5db154.jpg",
      alt: "Trattamento endodontico",
      icon: icons.endodontics,
    },
    {
      slug: "gnathology",
      titles: ["Gnatologia"],
      image: "/assets/generated/treatment-aligner.png",
      alt: "Bite trasparente per valutazione gnatologica",
      icon: icons.gnathology,
    },
    {
      slug: "pedodontics",
      titles: ["Pedodonzia", "Pediatric Dentistry"],
      image: "/mirror-assets/0b18b64a0ee4eb07.jpg",
      alt: "Odontoiatria per bambini",
      icon: icons.pedodontics,
    },
  ];

  const cardsByTitle = new Map();
  cards.forEach((card) => {
    card.titles.forEach((title) => cardsByTitle.set(normalizeTitle(title), card));
  });

  const normalizeDetailLink = (card) => {
    const link = card.querySelector(".box-footer .elementskit-btn");
    if (!link) return;

    const brandPrimary =
      getComputedStyle(document.body).getPropertyValue("--brand-primary").trim() ||
      getComputedStyle(document.documentElement).getPropertyValue("--brand-primary").trim() ||
      "#0E384C";

    link.classList.add("treatment-card-detail-link");
    link.style.setProperty("background", "transparent", "important");
    link.style.setProperty("background-color", "transparent", "important");
    link.style.setProperty("background-image", "none", "important");
    link.style.setProperty("box-shadow", "none", "important");
    link.style.setProperty("color", brandPrimary, "important");
    link.style.setProperty("text-decoration", "none", "important");

    const arrow = link.querySelector("svg");
    if (arrow) {
      arrow.style.setProperty("color", brandPrimary, "important");
      arrow.style.setProperty("display", "block", "important");
      arrow.style.setProperty("overflow", "visible", "important");
      arrow.style.setProperty("stroke", brandPrimary, "important");
      arrow.style.setProperty("transform", "none", "important");
      arrow.style.setProperty("visibility", "visible", "important");
    }

    link.querySelectorAll("svg, svg *").forEach((node) => {
      node.style.setProperty("fill", "none", "important");
      node.style.setProperty("opacity", "1", "important");
      node.style.setProperty("stroke", brandPrimary, "important");
      node.style.setProperty("transform", "none", "important");
      node.style.setProperty("visibility", "visible", "important");
    });
  };

  const buildOrientationCard = () => {
    const wrapper = document.createElement("div");
    wrapper.className = "elementor-element elementor-element-orientation-quiz e-con-full e-flex e-con e-child mirror-orientation-card-wrap";
    wrapper.dataset.element_type = "container";
    wrapper.dataset.eType = "container";

    wrapper.innerHTML = [
      '<div class="elementor-element elementor-element-orientation-quiz-widget v2-service-item ekit-equal-height-disable elementor-widget elementor-widget-elementskit-icon-box" data-element_type="widget" data-e-type="widget" data-widget_type="elementskit-icon-box.default">',
      '<div class="elementor-widget-container">',
      '<div class="ekit-wid-con">',
      '<a class="elementskit-infobox text-left text-left icon-top-align elementor-animation- gradient-active hover_from_bottom" data-treatment-card="orientation" href="/orientamento-sorriso/" aria-label="Apri il modulo quiz di orientamento sorriso">',
      '<div class="elementskit-box-header elementor-animation-">',
      '<div class="elementskit-info-box-icon">' + icons.guidance + '</div>',
      '</div>',
      '<div class="box-body">',
      '<h3 class="elementskit-info-box-title">Hai già in mente un risultato che vuoi ottenere ma non sai da dove iniziare?</h3>',
      '<div class="box-footer disable_hover_button">',
      '<div class="btn-wraper">',
      '<span class="elementskit-btn whitespace--normal">',
      'Clicca qui',
      '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="14" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M1 7H15M15 7L9 1M15 7L9 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>',
      '</span>',
      '</div>',
      '</div>',
      '</div>',
      '</a>',
      '</div>',
      '</div>',
      '</div>',
    ].join("");

    return wrapper;
  };

  const addOrientationCard = () => {
    if (!document.body.classList.contains("home")) return;
    if (document.querySelector('[data-treatment-card="orientation"]')) return;

    const serviceCards = Array.from(document.querySelectorAll(".elementor-7051 .v2-service-item .elementskit-infobox[data-treatment-card]"));
    const lastCard = serviceCards[serviceCards.length - 1];
    const lastWrapper = lastCard?.closest(".e-con.e-child");
    const grid = lastWrapper?.parentElement;

    if (!grid || !lastWrapper) return;

    const wrapper = buildOrientationCard();
    grid.append(wrapper);
  };

  const decorateCards = () => {
    document.querySelectorAll(".v2-service-item .elementskit-infobox").forEach((card) => {
      const titleElement = card.querySelector(".elementskit-info-box-title");
      const config = cardsByTitle.get(normalizeTitle(titleElement?.textContent));

      if (!config) return;

      card.dataset.treatmentCard = config.slug;

      const iconBox = card.querySelector(".elementskit-info-box-icon");
      if (iconBox && iconBox.dataset.treatmentIcon !== config.slug) {
        iconBox.innerHTML = config.icon;
        iconBox.dataset.treatmentIcon = config.slug;
      }

      if (!card.querySelector(".treatment-card-media")) {
        const media = document.createElement("div");
        media.className = "treatment-card-media";

        const image = document.createElement("img");
        image.src = config.image;
        image.alt = config.alt;
        image.loading = "lazy";
        image.decoding = "async";

        media.append(image);
        card.prepend(media);
      }

      normalizeDetailLink(card);
    });

    addOrientationCard();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", decorateCards, { once: true });
  } else {
    decorateCards();
  }
})();
`;

const reviewsPageScript = `
(() => {
  const app = document.querySelector("[data-reviews-app]");
  const form = document.querySelector("[data-review-form]");
  if (!app || !form) return;

  const list = app.querySelector("[data-reviews-list]");
  const message = form.querySelector("[data-review-message]");
  const submitButton = form.querySelector("[data-review-submit]");
  const reviewsWrap = app.querySelector(".glsr-reviews-wrap");
  const sourceReviews = ${JSON.stringify(sourceReviews).replace(/</g, "\\u003c")};
  const REVIEWS_PER_PAGE = ${REVIEWS_PER_PAGE};
  const REVIEWS_PAGE_PATH = "${REVIEWS_PAGE_PATH}";
  let userReviews = [];

  const escapeHtml = (value) =>
    String(value || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  const clampRating = (value) => {
    const rating = Number(value);
    if (!Number.isFinite(rating)) return 1;
    return Math.min(5, Math.max(1, Math.round(rating)));
  };

  const formatDate = (value) => {
    if (!value) return new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(new Date());
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" }).format(date);
  };

  const reviewsPageHref = (pageNumber) => pageNumber <= 1 ? REVIEWS_PAGE_PATH : REVIEWS_PAGE_PATH + "?reviews-page=" + pageNumber;

  const stars = (rating) => {
    const normalizedRating = clampRating(rating);
    return Array.from({ length: 5 }, (_, index) =>
      '<span class="glsr-star ' + (index < normalizedRating ? "glsr-star-full" : "glsr-star-empty") + '" aria-hidden="true"></span>',
    ).join("");
  };

  const normalizeReview = (review) => ({
    id: String(review.id || "user-" + Date.now()),
    rating: clampRating(review.rating),
    title: String(review.title || ""),
    dateLabel: String(review.dateLabel || formatDate(review.createdAt || review.created_at)),
    content: String(review.content || ""),
    author: String(review.author || ""),
    source: review.source || "site",
  });

  const buildReview = (review, type) => {
    const normalized = normalizeReview(review);
    const rating = clampRating(normalized.rating);
    const htmlId = normalized.id.startsWith("review-") ? normalized.id : "review-" + normalized.id;

    return '<div class="glsr-review" data-type="' + escapeHtml(type || normalized.source || "site") + '" id="' + escapeHtml(htmlId) + '" data-assigned=\\'[]\\' data-review-id="' + escapeHtml(normalized.id) + '">' +
      '<div class="glsr-review-title"><h4 class="glsr-tag-value">' + escapeHtml(normalized.title) + '</h4></div>' +
      '<div class="glsr-review-rating"><div class="glsr-star-rating glsr-stars" role="img" aria-label="Rated ' + rating + ' out of 5 stars" data-rating="' + rating + '" data-reviews="0">' + stars(rating) + '</div></div> <div class="glsr-review-date"><span class="glsr-tag-value">' + escapeHtml(normalized.dateLabel) + '</span></div>' +
      '<div class="glsr-review-content"><div class="glsr-tag-value" data-expanded="false"><p>' + escapeHtml(normalized.content) + '</p></div></div>' +
      '<div class="glsr-review-author"><span class="glsr-tag-value">' + escapeHtml(normalized.author) + '</span></div> ' +
      '</div>';
  };

  const getReviews = () => userReviews.concat(sourceReviews);

  const totalPages = () => Math.max(1, Math.ceil(getReviews().length / REVIEWS_PER_PAGE));

  const pageFromLocation = () => {
    const page = Number(new URLSearchParams(window.location.search).get("reviews-page") || "1");
    if (!Number.isFinite(page)) return 1;
    return Math.min(totalPages(), Math.max(1, Math.round(page)));
  };

  const buildPagination = (currentPage) => {
    const total = totalPages();
    if (total <= 1) return "";

    const links = [];
    if (currentPage > 1) {
      links.push('<a class="page-numbers prev" data-page="' + (currentPage - 1) + '" href="' + reviewsPageHref(currentPage - 1) + '">Previous</a>');
    }

    for (let pageNumber = 1; pageNumber <= total; pageNumber += 1) {
      if (pageNumber === currentPage) {
        links.push('<span class="page-numbers current" aria-current="page" data-page="' + pageNumber + '"><span class="meta-nav screen-reader-text">Page </span>' + pageNumber + '</span>');
      } else {
        links.push('<a class="page-numbers" data-page="' + pageNumber + '" href="' + reviewsPageHref(pageNumber) + '"><span class="meta-nav screen-reader-text">Page </span>' + pageNumber + '</a>');
      }
    }

    if (currentPage < total) {
      links.push('<a class="page-numbers next" data-page="' + (currentPage + 1) + '" href="' + reviewsPageHref(currentPage + 1) + '">Next</a>');
    }

    return '<div class="glsr-pagination glsr-ajax-pagination" data-id="glsr_85761207" data-pagination="ajax" data-reviews-pagination><div class="pagination">' +
      '<nav class="navigation" role="navigation">' +
      '<h2 class="screen-reader-text">Site Reviews navigation</h2>' +
      '<div class="nav-links">' + links.join("") + '</div>' +
      '</nav>' +
      '</div></div>';
  };

  const renderPage = (requestedPage, options = {}) => {
    if (!list) return;
    const page = Math.min(totalPages(), Math.max(1, Math.round(Number(requestedPage) || 1)));
    const start = (page - 1) * REVIEWS_PER_PAGE;
    const html = getReviews().slice(start, start + REVIEWS_PER_PAGE).map((review) => {
      const reviewType = String(review.id || "").startsWith("review-") ? "local" : (review.source || "site");
      return buildReview(review, reviewType);
    }).join("");

    app.classList.add("glsr-hide");
    list.innerHTML = html || '<p>Non ci sono ancora recensioni pubblicate.</p>';

    const pagination = app.querySelector("[data-reviews-pagination]");
    const nextPagination = buildPagination(page);
    if (pagination) {
      pagination.outerHTML = nextPagination;
    } else if (nextPagination && reviewsWrap) {
      reviewsWrap.insertAdjacentHTML("beforeend", nextPagination);
    }

    window.setTimeout(() => app.classList.remove("glsr-hide"), 20);

    if (options.push) {
      window.history.pushState({}, "", reviewsPageHref(page));
    }

    if (options.scroll && app.scrollIntoView) {
      app.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  };

  const setMessage = (text, type = "") => {
    if (!message) return;
    message.textContent = text;
    message.classList.toggle("glsr-form-success", type === "success");
    message.classList.toggle("glsr-form-failed", type === "error");
    if (!text) {
      message.classList.remove("glsr-form-success", "glsr-form-failed");
    }
  };

  const clearFieldErrors = () => {
    form.querySelectorAll(".glsr-field-is-invalid").forEach((field) => field.classList.remove("glsr-field-is-invalid"));
    form.querySelectorAll(".glsr-is-invalid").forEach((field) => field.classList.remove("glsr-is-invalid"));
    form.querySelectorAll(".glsr-field-error").forEach((field) => {
      field.textContent = "";
    });
  };

  const markInvalid = (fieldName, text) => {
    const field = form.querySelector('[data-field="' + fieldName + '"]');
    if (!field) return;
    field.classList.add("glsr-field-is-invalid");
    const input = field.querySelector("input, select, textarea");
    input?.classList.add("glsr-is-invalid");
    const error = field.querySelector(".glsr-field-error");
    if (error) error.textContent = text;
  };

  const readPayload = () => {
    const data = new FormData(form);
    return {
      rating: data.get("site-reviews[rating]"),
      title: data.get("site-reviews[title]"),
      content: data.get("site-reviews[content]"),
      author: data.get("site-reviews[name]"),
      email: data.get("site-reviews[email]"),
      consent: data.get("site-reviews[terms]") === "1",
      website: data.get("site-reviews[3831cc21]") || data.get("website") || "",
    };
  };

  const validatePayload = (payload) => {
    clearFieldErrors();
    let valid = true;

    if (!payload.rating) {
      markInvalid("rating", "Seleziona una valutazione da 1 a 5 stelle");
      valid = false;
    }
    if (!String(payload.title || "").trim()) {
      markInvalid("title", "Inserisci un titolo valido");
      valid = false;
    }
    if (!String(payload.content || "").trim()) {
      markInvalid("content", "Inserisci un testo recensione valido");
      valid = false;
    }
    if (!String(payload.author || "").trim()) {
      markInvalid("name", "Inserisci un nome valido");
      valid = false;
    }
    if (!String(payload.email || "").trim()) {
      markInvalid("email", "Inserisci un indirizzo email valido");
      valid = false;
    }
    if (!payload.consent) {
      markInvalid("terms", "Conferma che la recensione è basata sulla tua esperienza");
      valid = false;
    }

    return valid;
  };

  const loadReviews = async () => {
    try {
      const response = await fetch("/api/reviews", {
        headers: { Accept: "application/json" },
        cache: "no-store",
      });
      if (!response.ok) return;
      const payload = await response.json();
      if (!Array.isArray(payload.reviews)) return;
      userReviews = payload.reviews.map(normalizeReview);
      renderPage(pageFromLocation());
    } catch {
      renderPage(pageFromLocation());
    }
  };

  app.addEventListener("click", (event) => {
    const link = event.target.closest(".page-numbers");
    if (!link || !link.dataset.page) return;
    event.preventDefault();
    renderPage(Number(link.dataset.page), { push: true, scroll: true });
  });

  form.addEventListener("input", (event) => {
    const field = event.target.closest(".glsr-field");
    if (!field) return;
    field.classList.remove("glsr-field-is-invalid");
    field.querySelector(".glsr-is-invalid")?.classList.remove("glsr-is-invalid");
    const error = field.querySelector(".glsr-field-error");
    if (error) error.textContent = "";
  });

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const payload = readPayload();

    if (!validatePayload(payload)) {
      setMessage("Compila tutti i campi obbligatori prima di inviare.", "error");
      return;
    }

    submitButton?.setAttribute("aria-busy", "true");
    submitButton?.setAttribute("disabled", "");
    setMessage("Invio della recensione in corso...");

    try {
      const response = await fetch("/api/reviews", {
        method: "POST",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || !result.ok) {
        throw new Error(result.error || "Invio non riuscito");
      }

      if (result.review) {
        userReviews = [normalizeReview(result.review)].concat(userReviews);
      }
      form.reset();
      clearFieldErrors();
      renderPage(1, { push: true });
      setMessage("Grazie, la tua recensione è stata pubblicata.", "success");
    } catch (error) {
      setMessage(error instanceof Error ? error.message : "Invio non riuscito. Riprova tra poco.", "error");
    } finally {
      submitButton?.setAttribute("aria-busy", "false");
      submitButton?.removeAttribute("disabled");
    }
  });

  window.addEventListener("popstate", () => renderPage(pageFromLocation()));

  renderPage(pageFromLocation());
  loadReviews();
})();
`;
---

