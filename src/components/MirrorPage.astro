<span class="glsr-toggle-switch">
<input type="checkbox" class="glsr-input-toggle" id="glsr_5cfbac45-terms-1" name="site-reviews[terms]" value="1" /> &#8203; <!-- zero-space character used for alignment -->
<span class="glsr-toggle-track"></span>
</span>
</span>
</span>
<div class="glsr-field-error"></div>
</div>
<div class="glsr-form-message" data-review-message role="status" aria-live="polite">
</div>
<div data-field="submit-button">
<div class="wp-block-buttons is-layout-flex">
<div class="wp-block-button">
<button type="submit" class="glsr-button wp-block-button__link wp-element-button" aria-busy="false" data-loading="Submitting, please wait..." data-review-submit>Inserisci recensione</button>
</div>
</div>
</div>
</form>
</div></div></p>`;

const reviewsListMarkup = `<p><div class="glsr glsr-default" id="glsr_85761207" data-from="shortcode" data-shortcode="site_reviews" data-pagination="ajax" data-reviews-app><div class="glsr-reviews-wrap">
<div class="glsr-reviews" data-reviews-list>
${getSourceReviewsPage(1).map((review) => buildGlsrReview(review)).join("\n")}
</div>
${buildGlsrPagination(1, reviewsPageCount)}
</div></div></p>`;

const applyReviewsPageBody = (html: string) => {
  if (!isReviewsPage) return html;

  return html
    .replace(
      /<p><div class="glsr glsr-default" id="glsr_5cfbac45"[\s\S]*?<\/div><\/div><\/p>/,
      reviewsFormMarkup,
    )
    .replace(
      /<p><div class="glsr glsr-default" id="glsr_85761207"[\s\S]*?<\/div><\/div><\/p>/,
      reviewsListMarkup,
    )
    .replace(/<script\b[^>]*id=["']site-reviews-js-before["'][^>]*>[\s\S]*?<\/script>\s*/gi, "")
    .replace(/<script\b[^>]*id=["']site-reviews-js["'][^>]*>[\s\S]*?<\/script>\s*/gi, "")
    .replace(/<script\b[^>]*id=["']site-reviews-js-after["'][^>]*>[\s\S]*?<\/script>\s*/gi, "");
};

const applyActivityIndexItalianHead = (html: string) => {
  if (page.path !== "/attivita/") return html;

  return html
