  if (!aboutBreadcrumbPagePaths.has(page.path)) return html;

  return html
    .replaceAll("https://sorrisoesalutemonza.it/mirror-assets/d11d1a58bbcb5793.jpg", aboutSectionImageUrl)
    .replaceAll("https://sorrisoesalutemonza.it/mirror-assets/e412d210c2a1a484.jpg", aboutSectionImageUrl)
    .replace('<meta property="og:image:width" content="524" />', '<meta property="og:image:width" content="1254" />')
    .replace('<meta property="og:image:height" content="800" />', '<meta property="og:image:height" content="1254" />')
    .replace('<meta property="og:image:type" content="image/png" />', '<meta property="og:image:type" content="image/png" />')
    .replace('"width":524,"height":800', '"width":1254,"height":1254');
};

