---
import { readFile } from "node:fs/promises";
import path from "node:path";
import BrandPalette from "./BrandPalette.astro";
import GoogleAdsTracking from "./GoogleAdsTracking.astro";
import MirrorFooter from "./MirrorFooter.astro";
import PageLoader from "./PageLoader.astro";
import manifest from "../data/mirror/manifest.json";
import { sourceReviews } from "../data/reviews-seed";

interface Props {
  mirrorPath: string;
}

const { mirrorPath } = Astro.props;
const page = manifest.pages.find((entry) => entry.path === mirrorPath);

if (!page) {
  throw new Error(`Missing mirrored page for ${mirrorPath}`);
}

const pagesDir = path.resolve("src/data/mirror/pages");
const [rawHead, rawBody] = await Promise.all([
  readFile(path.join(pagesDir, page.headFile), "utf8"),
  readFile(path.join(pagesDir, page.bodyFile), "utf8"),
]);

const replaceFirst = (source: string, search: string, replacement: string) => source.replace(search, replacement);

const applyBrandColorTokens = (html: string) =>
  html
    .replace(/#1e37b7/gi, "#0E384C")
    .replace(/#172d96/gi, "#082A38")
    .replace(/#0f1f63/gi, "#082A38")
    .replace(/rgba\(\s*30\s*,\s*55\s*,\s*183\s*,/gi, "rgba(14, 56, 76,")
    .replace(/rgba\(\s*15\s*,\s*31\s*,\s*99\s*,/gi, "rgba(8, 42, 56,");

