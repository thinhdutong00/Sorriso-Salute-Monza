  "/attivita/":
    "Scopri trattamenti chiari e personalizzati per prevenire, curare e valorizzare il tuo sorriso.",
  "/attivita/chirurgia-orale/":
    "Affronta estrazioni e piccoli interventi con un percorso pianificato, attento al comfort e al recupero.",
  "/attivita/endodonzia/":
    "Salva il dente naturale, elimina il dolore e ripristina la funzione con una devitalizzazione precisa.",
  "/attivita/estetica-del-sorriso/":
    "Migliora colore, forma e armonia dei denti con trattamenti mirati a un sorriso naturale.",
  "/attivita/gnatologia/":
    "Riduci dolori mandibolari, tensioni e disturbi della masticazione con una valutazione funzionale mirata.",
  "/attivita/igiene-orale-e-profilassi/":
    "Proteggi denti e gengive con controlli e igiene professionale pensati per prevenire problemi futuri.",
  "/attivita/odontoiatria-conservativa/":
    "Cura carie e lesioni preservando il più possibile il dente naturale, estetica e funzionalità.",
  "/attivita/ortodonzia/":
    "Allinea il sorriso, migliora la masticazione e scegli soluzioni discrete adatte alla tua quotidianità.",
  "/attivita/parodontologia/":
    "Ferma i problemi gengivali, proteggi i denti e ritrova stabilità con cure mirate.",
  "/attivita/pedodonzia/":
    "Accompagna i bambini dal dentista con cure delicate, prevenzione e un approccio rassicurante.",
  "/attivita/protesi-dentale/":
    "Ripristina denti mancanti, masticazione ed estetica con soluzioni fisse o mobili su misura.",
};

const conventionPagePaths = new Set([
  "/convenzioni-dirette-studio-dentistico-monza/",
  "/convenzioni-dirette/",
  "/convenzioni-indirette/",
]);
const aboutBreadcrumbPagePaths = new Set(["/chi-siamo/", "/chi-siamo-studio-dentistico-monza/"]);
const aboutSectionImageUrl = "https://sorrisoesalutemonza.it/assets/brand/sorriso-salute-sala-operativa.png";
const isReviewsPage = page.path === "/recensioni-studio-dentistico-monza/";

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");

const applyActivityHeroDescription = (html: string) => {
  const description = activityHeroDescriptions[page.path];
  if (!description) return html;

  return html.replace(
    /<ol class="ekit-breadcrumb">[\s\S]*?<\/ol>/,
    `<p class="activity-hero-description">${escapeHtml(description)}</p>`,
  );
};

const removeReviewsHeroBreadcrumb = (html: string) => {
  if (page.path !== "/recensioni-studio-dentistico-monza/") return html;

  return html.replace(/<ol class="ekit-breadcrumb">[\s\S]*?<\/ol>/, "");
};

const removeConventionHeroBreadcrumb = (html: string) => {
  if (!conventionPagePaths.has(page.path)) return html;

  return html.replace(/<ol class="ekit-breadcrumb">[\s\S]*?<\/ol>/, "");
};

const removeAboutHeroBreadcrumb = (html: string) => {
  if (!aboutBreadcrumbPagePaths.has(page.path)) return html;

  return html.replace(/<ol class="ekit-breadcrumb">[\s\S]*?<\/ol>/, "");
};

type DisplayReview = {
  id: string | number;
  rating: number;
  title: string;
  dateLabel: string;
  content: string;
  author: string;
  sourcePage?: number;
};

const REVIEWS_PER_PAGE = 5;
const REVIEWS_PAGE_PATH = "/recensioni-studio-dentistico-monza/";
const reviewsPageCount = Math.max(1, Math.ceil(sourceReviews.length / REVIEWS_PER_PAGE));

const clampRating = (rating: number) => Math.min(5, Math.max(1, Math.round(rating)));

const buildReviewsPageHref = (pageNumber: number) =>
  pageNumber <= 1 ? REVIEWS_PAGE_PATH : `${REVIEWS_PAGE_PATH}?reviews-page=${pageNumber}`;

const buildGlsrStars = (rating: number) => {
  const normalizedRating = clampRating(rating);

  return Array.from({ length: 5 }, (_, index) =>
    `<span class="glsr-star ${index < normalizedRating ? "glsr-star-full" : "glsr-star-empty"}" aria-hidden="true"></span>`,
  ).join("");
};

const buildGlsrReview = (review: DisplayReview, type = "local") => {
  const rating = clampRating(review.rating);
  const reviewId = escapeHtml(String(review.id));

  return `<div class="glsr-review" data-type="${escapeHtml(type)}" id="${reviewId}" data-assigned='[]' data-review-id="${reviewId}">
<div class="glsr-review-title"><h4 class="glsr-tag-value">${escapeHtml(review.title)}</h4></div>
<div class="glsr-review-rating"><div class="glsr-star-rating glsr-stars" role="img" aria-label="Rated ${rating} out of 5 stars" data-rating="${rating}" data-reviews="0">${buildGlsrStars(rating)}</div></div> <div class="glsr-review-date"><span class="glsr-tag-value">${escapeHtml(review.dateLabel)}</span></div>
<div class="glsr-review-content"><div class="glsr-tag-value" data-expanded="false"><p>${escapeHtml(review.content)}</p></div></div>
<div class="glsr-review-author"><span class="glsr-tag-value">${escapeHtml(review.author)}</span></div>
</div>`;
};

const getSourceReviewsPage = (pageNumber: number) =>
  sourceReviews.slice((pageNumber - 1) * REVIEWS_PER_PAGE, pageNumber * REVIEWS_PER_PAGE);

const buildGlsrPagination = (currentPage: number, totalPages: number) => {
  if (totalPages <= 1) return "";

  const links: string[] = [];

  if (currentPage > 1) {
    links.push(`<a class="page-numbers prev" data-page="${currentPage - 1}" href="${buildReviewsPageHref(currentPage - 1)}">Previous</a>`);
  }

  for (let pageNumber = 1; pageNumber <= totalPages; pageNumber += 1) {
    if (pageNumber === currentPage) {
      links.push(`<span class="page-numbers current" aria-current="page" data-page="${pageNumber}"><span class="meta-nav screen-reader-text">Page </span>${pageNumber}</span>`);
    } else {
      links.push(`<a class="page-numbers" data-page="${pageNumber}" href="${buildReviewsPageHref(pageNumber)}"><span class="meta-nav screen-reader-text">Page </span>${pageNumber}</a>`);
    }
  }

  if (currentPage < totalPages) {
    links.push(`<a class="page-numbers next" data-page="${currentPage + 1}" href="${buildReviewsPageHref(currentPage + 1)}">Next</a>`);
  }

  return `<div class="glsr-pagination glsr-ajax-pagination" data-id="glsr_85761207" data-pagination="ajax" data-reviews-pagination><div class="pagination">
<nav class="navigation" role="navigation">
<h2 class="screen-reader-text">Site Reviews navigation</h2>
<div class="nav-links">
${links.join("\n")}
</div>
</nav>
</div></div>`;
};

